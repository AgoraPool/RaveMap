---
import { renderSVG } from "uqr";
import { getEnv } from "../lib/server/env";

const simplexGroupUrl = getEnv().SIMPLEX_GROUP_URL;
const simplexGroupQrSvg = simplexGroupUrl
  ? renderSVG(simplexGroupUrl, {
      border: 3,
      ecc: "M",
      pixelSize: 6,
      whiteColor: "#fffef8",
      blackColor: "#000000",
    })
  : "";

const items = [
  {
    question: "Co je Kam Na Rave?",
    answer:
      "RaveMap je jednoduchý rozcestník pro underground akce. Veřejně ukáže vibe, termín a místo srazu, ale přesnou lokaci nechá zamčenou pro lidi s kódem.",
  },
  {
    question: "Kde najdu přesnou lokaci akce?",
    answer:
      "Přesná lokace se odemyká až na detailu konkrétní akce po zadání tajného kódu. Bez něj zůstává veřejná jen základní orientace a čas.",
  },
  {
    question: "Jak získám unlock kód?",
    answer:
      "Kód typicky sdílí organizátor přes svůj komunitní kanál, zprávu nebo vstupenkový proces. Pro domluvu doporučujeme SimpleX, protože nevyžaduje telefonní číslo ani veřejný profil.",
  },
  {
    question: "Proč SimpleX?",
    answer:
      "SimpleX je jednoduchý soukromý chat bez globální identity. Když organizátor přidá SimpleX kontakt, najdeš ho na detailu akce jako tlačítko Otevřít chat.",
  },
  {
    question: "Co když zadám špatný kód?",
    answer:
      "Web špatné pokusy omezuje, aby nešlo kódy jednoduše hádat. Když se párkrát spletete za sebou, odemykání se na chvíli zablokuje.",
  },
  {
    question: "Jsou všechny akce veřejně viditelné?",
    answer:
      "Ne. Organizátor může akci nechat rozpracovanou a publikovat ji až ve chvíli, kdy je připravená jít ven.",
  },
  {
    question: "Je tohle hotový produkční systém?",
    answer:
      "Zatím ne. Je to bezpečnostně zaměřené MVP, které ukazuje princip oddělení veřejných a tajných dat, admin tvorbu akcí a chráněné odemykání lokace.",
  },
];
---

<section class="faq" id="faq">
  <div class="faq-bg"></div>
  <h2 class="faq-title">FAQ</h2>
  <div class="faq-table">
    {
      simplexGroupUrl && (
        <section class="simplex-group">
          <div class="simplex-copy">
            <span>SimpleX skupina</span>
            <h3>Připoj se bez telefonu a veřejného profilu</h3>
            <p>Otevři odkaz v SimpleX, nebo naskenuj QR kód.</p>
            <a href={simplexGroupUrl} target="_blank" rel="noreferrer">Otevřít skupinu</a>
          </div>
          <div class="simplex-qr" aria-label="QR kód pro SimpleX skupinu" set:html={simplexGroupQrSvg} />
        </section>
      )
    }
    {items.map((item, index) => (
      <details class="faq-item">
        <summary class="faq-summary">
          <span class="faq-index">{String(index + 1).padStart(2, "0")}.</span>
          <span class="faq-question">{item.question}</span>
        </summary>
        <p class="faq-answer">{item.answer}</p>
      </details>
    ))}
  </div>
  <img src="/bunkr.png" class="bunkr" alt="Dekorativní bunkr" />
</section>

<style>
  .faq {
    width: 100vw;
    min-height: 100svh;
    margin: 0;
    display: flex;
    overflow: hidden;
  }
  .faq-bg {
    position: absolute;
    width: 100svw;
    height: 100svh;
    opacity: 0.02;
    background: url("/bg.jpeg");
    z-index: 0;
    background-size: cover;
  }
  .faq-title {
    font-size: 12rem;
    writing-mode: vertical-rl;
    text-orientation: upright;
  }
  .faq-table {
    width: 70%;
    max-height: 82svh;
    display: flex;
    margin: auto 40px;
    border: 3px solid black;
    background-color: #c00;
    flex-direction: column;
    overflow: auto;
    position: relative;
    z-index: 1;
  }
  .faq-item {
    border-bottom: 1px solid black;
  }
  .simplex-group {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 180px;
    gap: 16px;
    align-items: center;
    padding: 18px;
    border-bottom: 3px solid #000;
    background: #8ef1b0;
  }
  .simplex-copy {
    display: grid;
    gap: 8px;
    min-width: 0;
  }
  .simplex-copy span {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 900;
  }
  .simplex-copy h3 {
    margin: 0;
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    line-height: 1;
    overflow-wrap: anywhere;
  }
  .simplex-copy p {
    margin: 0;
    line-height: 1.45;
    font-weight: 700;
  }
  .simplex-copy a {
    width: fit-content;
    border: 2px solid #000;
    background: #000;
    color: #c00;
    padding: 10px 12px;
    text-decoration: none;
    font-weight: 900;
  }
  .simplex-copy a:hover {
    background: #c00;
    color: #000;
  }
  .simplex-qr {
    width: 180px;
    border: 3px solid #000;
    background: #fffef8;
    padding: 8px;
    box-sizing: border-box;
  }
  .simplex-qr :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }
  .faq-item:last-child {
    border-bottom: 0;
  }
  .faq-summary {
    list-style: none;
    padding: 14px 18px;
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 16px;
    align-items: center;
    cursor: pointer;
    font-size: 1.45rem;
  }
  .faq-summary::-webkit-details-marker {
    display: none;
  }
  .faq-item[open] .faq-summary,
  .faq-summary:hover {
    color: #c00;
    background-color: #000;
  }
  .faq-index {
    font-size: 2rem;
  }
  .faq-question {
    font-size: 1.45rem;
    line-height: 1.2;
  }
  .faq-answer {
    margin: 0;
    padding: 0 18px 18px 104px;
    font-size: 1rem;
    line-height: 1.5;
  }
  .bunkr {
    position: absolute;
    z-index: -1;
    bottom: -60px;
    left: -70px;
    width: 450px;
    opacity: 1;
    transform: scaleX(-1);
  }
  @media (max-width: 1024px) {
    .faq-title {
      font-size: 8rem;
    }
    .faq-table {
      width: 78%;
      margin: auto 20px;
    }
  }
  @media (max-width: 768px) {
    .faq {
      min-height: 100svh;
    }
    .faq-title {
      font-size: 6rem;
    }
    .faq-table {
      width: 72svw;
      max-height: 82svh;
      margin: 10px auto;
      margin-left: -15px;
    }
    .faq-summary {
      grid-template-columns: 48px 1fr;
      gap: 10px;
      padding: 12px;
    }
    .faq-index {
      font-size: 1.2rem;
    }
    .faq-question {
      font-size: 1rem;
    }
    .faq-answer {
      padding: 0 12px 14px 70px;
      font-size: 0.9rem;
    }
    .simplex-group {
      grid-template-columns: 1fr;
      padding: 12px;
    }
    .simplex-copy h3 {
      font-size: 1.2rem;
    }
    .simplex-copy a {
      width: 100%;
      box-sizing: border-box;
      text-align: center;
    }
    .simplex-qr {
      width: min(100%, 220px);
      justify-self: center;
    }
    .bunkr {
      position: absolute;
      z-index: -1;
      bottom: 0;
      left: -20px;
      width: 150px;
      opacity: 1;
      transform: scaleX(-1);
    }
  }
</style>
