---
import { getNostrEventRepository } from "../lib/server/nostr-repository";

const {
  limit = 80,
  variant = "full",
} = Astro.props as { limit?: number; variant?: "full" | "preview" };
const isPreview = variant === "preview";
const repository = getNostrEventRepository();
const list = await repository.listPublishedEvents(limit);
const rsvpSummaries: Record<string, { accepted: number; tentative: number }> = isPreview
  ? {}
  : await repository.getRsvpSummariesForEvents(list).catch(() => ({}));

const formatter = new Intl.DateTimeFormat("cs-CZ", {
  dateStyle: "medium",
  timeStyle: "short",
});
---

<section class:list={["akce", isPreview && "akce-preview"]} id="akce">
  <div class="akce-bg"></div>
  <div class="akce-actions">
    <a class="submit-link" href="/submit">Přidat akci</a>
    {isPreview && <a class="all-events-link" href="/akce">Všechny akce</a>}
  </div>
  <h2 class="akce-title">AKCE</h2>
  <div class="akce-table">
    {list.length === 0 ? (
      <div class="empty-state">Žádné akce zatím nejsou publikované.</div>
    ) : (
      <>
        {
          !isPreview && (
            <div class="akce-sort-row" aria-label="Řazení akcí">
              <span class="akce-sort-spacer" aria-hidden="true"></span>
              <button type="button" data-sort-key="name" aria-label="Seřadit podle názvu">
                Název <span data-sort-indicator="name">-</span>
              </button>
              <button type="button" data-sort-key="date" aria-label="Seřadit podle data">
                Datum <span data-sort-indicator="date">↑</span>
              </button>
              <button type="button" data-sort-key="rsvp" aria-label="Seřadit podle účasti">
                Účast <span data-sort-indicator="rsvp">-</span>
              </button>
              <button type="button" data-sort-key="location" aria-label="Seřadit podle lokality">
                Lokalita <span data-sort-indicator="location">-</span>
              </button>
            </div>
          )
        }
        <div class="akce-list" data-akce-list>
          {list.map((item) => {
            const rsvp = rsvpSummaries[item.slug] ?? { accepted: 0, tentative: 0 };
            const rsvpTotal = rsvp.accepted + rsvp.tentative;
            return (
              <a
                class="akce-item"
                href={`/akce/${item.slug}`}
                data-name={item.title.toLocaleLowerCase("cs-CZ")}
                data-date={item.startsAt.getTime()}
                data-rsvp={rsvpTotal}
                data-location={item.publicLocation.toLocaleLowerCase("cs-CZ")}
              >
                <span class="akce-poster-cell" aria-hidden={!item.coverImageUrl}>
                  {
                    item.coverImageUrl && (
                      <img
                        class="akce-img"
                        src={item.coverImageUrl}
                        alt={item.title}
                        loading="lazy"
                        decoding="async"
                        referrerpolicy="no-referrer"
                      />
                    )
                  }
                </span>
                <h3 class="akce-name">{item.title}</h3>
                <div class="akce-date">{formatter.format(item.startsAt)}</div>
                {
                  !isPreview && (
                    <div class="akce-rsvp" aria-label={`${rsvp.accepted} jde, ${rsvp.tentative} možná`}>
                      <strong>{rsvpTotal}</strong>
                      <small>
                        {rsvp.accepted} jde / {rsvp.tentative} možná
                      </small>
                    </div>
                  )
                }
                <div class="akce-location">
                  <span>{item.publicLocation}</span>
                  <small>{item.accessType === "gated" ? "na kód" : item.source ? "import" : "veřejná"}</small>
                </div>
              </a>
            );
          })}
        </div>
      </>
    )}
  </div>
  <img src="/bunkr.png" class="bunkr" alt="Dekorativní bunkr" />
</section>

<script>
  const eventList = document.querySelector("[data-akce-list]");
  const sortButtons = [...document.querySelectorAll("[data-sort-key]")];
  const sortIndicators = [...document.querySelectorAll("[data-sort-indicator]")];
  const collator = new Intl.Collator("cs-CZ", { sensitivity: "base", numeric: true });
  const sortState = {
    key: "date",
    direction: "asc",
  };

  function valueFor(row, key) {
    if (!(row instanceof HTMLElement)) return "";
    if (key === "date") return Number(row.dataset.date || 0);
    if (key === "rsvp") return Number(row.dataset.rsvp || 0);
    if (key === "location") return row.dataset.location || "";
    return row.dataset.name || "";
  }

  function compareRows(left, right, key) {
    const leftValue = valueFor(left, key);
    const rightValue = valueFor(right, key);
    if (typeof leftValue === "number" && typeof rightValue === "number") {
      return leftValue - rightValue;
    }
    return collator.compare(String(leftValue), String(rightValue));
  }

  function renderSortState() {
    for (const indicator of sortIndicators) {
      if (!(indicator instanceof HTMLElement)) continue;
      indicator.textContent = indicator.dataset.sortIndicator === sortState.key ? (sortState.direction === "asc" ? "↑" : "↓") : "-";
    }

    for (const button of sortButtons) {
      if (!(button instanceof HTMLButtonElement)) continue;
      const active = button.dataset.sortKey === sortState.key;
      button.dataset.active = String(active);
      button.setAttribute("aria-sort", active ? (sortState.direction === "asc" ? "ascending" : "descending") : "none");
    }
  }

  function sortEvents(key) {
    if (!(eventList instanceof HTMLElement)) return;
    sortState.direction = sortState.key === key && sortState.direction === "asc" ? "desc" : "asc";
    sortState.key = key;

    const rows = [...eventList.querySelectorAll(".akce-item")];
    rows.sort((left, right) => {
      const result = compareRows(left, right, key);
      return sortState.direction === "asc" ? result : -result;
    });

    eventList.replaceChildren(...rows);
    renderSortState();
  }

  for (const button of sortButtons) {
    button.addEventListener("click", () => {
      if (!(button instanceof HTMLButtonElement) || !button.dataset.sortKey) return;
      sortEvents(button.dataset.sortKey);
    });
  }

  renderSortState();
</script>

<style>
  .akce {
    position: relative;
    width: 100%;
    min-height: 100svh;
    margin: 0;
    display: flex;
    align-items: center;
    padding: clamp(24px, 4svh, 48px) 0;
    box-sizing: border-box;
    overflow: hidden;
  }
  .akce-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100svh;
    opacity: 0.02;
    background: url("/bg.jpeg");
    z-index: 0;
    background-size: cover;
  }
  .akce-title {
    font-size: 12rem;
    writing-mode: vertical-rl;
    text-orientation: upright;
  }
  .akce-actions {
    position: absolute;
    z-index: 2;
    top: 24px;
    right: 24px;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
  }
  .submit-link,
  .all-events-link {
    border: 2px solid #000;
    background: #fff6df;
    color: #000;
    padding: 9px 11px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 900;
  }
  .all-events-link {
    background: #000;
    color: #c00;
  }
  .submit-link:hover,
  .all-events-link:hover {
    background: #000;
    color: #c00;
  }
  .all-events-link:hover {
    background: #fff6df;
    color: #000;
  }
  .akce-table {
    position: relative;
    z-index: 1;
    width: 70%;
    min-width: 0;
    max-height: min(78svh, 760px);
    min-height: 0;
    display: flex;
    flex-direction: column;
    margin: auto 40px;
    border: 3px solid black;
    background-color: #c00;
    overflow: auto;
    overflow-x: clip;
    overscroll-behavior: contain;
    scrollbar-color: #000 #c00;
  }
  .akce-sort-row,
  .akce-item {
    width: 100%;
    box-sizing: border-box;
    min-width: 0;
    display: grid;
    grid-template-columns: 110px minmax(0, 1.45fr) minmax(130px, 0.9fr) minmax(92px, 0.55fr) minmax(140px, 0.9fr);
    align-items: center;
    gap: 16px;
  }
  .akce-sort-row {
    position: sticky;
    top: 0;
    z-index: 3;
    padding: 8px 18px;
    border-bottom: 3px solid black;
    background: #000;
  }
  .akce-sort-row button {
    min-width: 0;
    width: 100%;
    border: 2px solid #fff6df;
    background: #c00;
    color: #fff6df;
    padding: 7px 8px;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: left;
    cursor: pointer;
  }
  .akce-sort-row button:hover,
  .akce-sort-row button[data-active="true"] {
    background: #fff6df;
    color: #000;
  }
  .akce-list {
    display: contents;
  }
  .akce-item {
    min-height: 80px;
    padding: 8px 18px;
    border-bottom: 1px solid black;
    font-size: 1.1rem;
    position: relative;
    cursor: pointer;
    text-decoration: none;
    color: black;
  }
  .akce-item:hover {
    color: #c00;
    background-color: #000;
  }
  .akce-poster-cell {
    width: 100px;
    height: 64px;
    display: block;
  }
  .akce-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .akce-name {
    font-size: 1.7rem;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .akce-date,
  .akce-rsvp,
  .akce-location {
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .akce-rsvp {
    display: grid;
    gap: 3px;
  }
  .akce-rsvp strong {
    font-size: 1.45rem;
    line-height: 1;
  }
  .akce-rsvp small {
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.2;
  }
  .akce-location {
    display: grid;
    gap: 3px;
  }
  .akce-location small {
    width: fit-content;
    border: 1px solid currentColor;
    padding: 2px 5px;
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 700;
  }
  .akce-preview {
    align-items: stretch;
    padding-top: 64px;
    overflow: visible;
  }
  .akce-preview .akce-table {
    width: min(1040px, 76%);
    max-height: none;
    overflow: visible;
  }
  .akce-preview .akce-list {
    display: block;
  }
  .akce-preview .akce-item {
    grid-template-columns: 96px minmax(0, 1.5fr) minmax(150px, 0.7fr) minmax(150px, 0.8fr);
    min-height: 88px;
    border-bottom-width: 2px;
  }
  .akce-preview .akce-item:last-child {
    border-bottom: 0;
  }
  .akce-preview .akce-name {
    font-size: 1.95rem;
    line-height: 0.95;
  }
  .akce-preview .akce-date {
    font-weight: 700;
  }
  .empty-state {
    padding: 24px;
    font-size: 1.4rem;
  }
  .bunkr {
    position: absolute;
    z-index: -1;
    bottom: -60px;
    right: -70px;
    width: 450px;
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .akce-title {
      font-size: 8rem;
    }
    .akce-table {
      width: 78%;
      margin: auto 20px;
    }
    .akce-sort-row,
    .akce-item {
      grid-template-columns: 80px minmax(0, 1.2fr) minmax(110px, 0.9fr) minmax(72px, 0.5fr);
      gap: 10px;
    }
    .akce-sort-row button[data-sort-key="location"],
    .akce-location {
      display: none;
    }
    .akce-name {
      font-size: 1.4rem;
    }
    .akce-rsvp strong {
      font-size: 1.2rem;
    }
    .akce-rsvp small {
      font-size: 0.62rem;
    }
    .akce-poster-cell {
      width: 72px;
      height: 52px;
    }
    .akce-preview .akce-table {
      width: 78%;
    }
    .akce-preview .akce-item {
      grid-template-columns: 72px minmax(0, 1fr) minmax(120px, 0.8fr) minmax(120px, 0.8fr);
    }
    .akce-preview .akce-location {
      display: grid;
    }
    .akce-preview .akce-name {
      font-size: 1.45rem;
    }
  }

  @media (max-width: 768px) {
    .akce {
      min-height: 100svh;
      display: grid;
      grid-template-rows: auto 1fr;
      align-items: stretch;
      gap: 10px;
      padding: 48px 10px 24px;
      overflow: hidden;
    }
    .akce-title {
      font-size: clamp(2.8rem, 18vw, 4.4rem);
      writing-mode: horizontal-tb;
      text-orientation: mixed;
      line-height: 0.9;
      padding: 0;
    }
    .akce-actions {
      top: 10px;
      right: 10px;
      left: 10px;
    }
    .submit-link,
    .all-events-link {
      font-size: 0.7rem;
      padding: 7px 8px;
    }
    .akce-table {
      width: 100%;
      max-width: 100%;
      min-width: 0;
      margin: 0;
      box-sizing: border-box;
      max-height: calc(100svh - 130px);
      display: block;
    }
    .akce-list {
      display: block;
    }
    .akce-item {
      grid-template-columns: 56px 1fr;
      grid-template-areas:
        "img name"
        "img date"
        "img rsvp";
      min-height: 74px;
      padding: 10px 12px;
      gap: 4px 10px;
      font-size: 0.95rem;
    }
    .akce-sort-row {
      position: static;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: stretch;
      gap: 6px;
      padding: 10px;
      min-height: 0;
      overflow: visible;
    }
    .akce-sort-row button {
      width: 100%;
      min-width: 0;
      min-height: 42px;
      font-size: 0.66rem;
      padding: 10px 9px;
      white-space: nowrap;
    }
    .akce-sort-row button[data-sort-key="rsvp"] {
      grid-column: 1 / -1;
    }
    .akce-sort-spacer {
      display: none;
    }
    .akce-sort-row::-webkit-scrollbar {
      display: none;
    }
    .akce-poster-cell {
      grid-area: img;
      width: 52px;
      height: 44px;
    }
    .akce-name {
      grid-area: name;
      font-size: 1.05rem;
      line-height: 1.2;
    }
    .akce-date {
      grid-area: date;
      font-size: 0.85rem;
    }
    .akce-rsvp {
      grid-area: rsvp;
      display: flex;
      align-items: baseline;
      gap: 6px;
    }
    .akce-rsvp strong {
      font-size: 1rem;
    }
    .akce-rsvp small {
      font-size: 0.68rem;
    }
    .akce-preview {
      min-height: auto;
      padding: 58px 10px 32px;
    }
    .akce-preview .akce-table {
      max-height: none;
      overflow: visible;
    }
    .akce-preview .akce-item {
      grid-template-columns: 56px minmax(0, 1fr);
      grid-template-areas:
        "img name"
        "img date"
        "img location";
      min-height: 76px;
    }
    .akce-preview .akce-name {
      font-size: 1.2rem;
    }
    .akce-preview .akce-location {
      grid-area: location;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.82rem;
    }
    .akce-preview .akce-location small {
      flex: 0 0 auto;
      font-size: 0.58rem;
    }
    .bunkr {
      width: 210px;
      right: -24px;
      bottom: -30px;
      opacity: 0.55;
    }
  }
</style>
