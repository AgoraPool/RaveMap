---
import { getNostrEventRepository } from "../lib/server/nostr-repository";

const { limit = 80 } = Astro.props as { limit?: number };
const list = await getNostrEventRepository().listPublishedEvents(limit);

const formatter = new Intl.DateTimeFormat("cs-CZ", {
  dateStyle: "medium",
  timeStyle: "short",
});
---

<section class="akce" id="akce">
  <div class="akce-bg"></div>
  <a class="submit-link" href="/submit">Přidat akci</a>
  <h2 class="akce-title">AKCE</h2>
  <div class="akce-table">
    {list.length === 0 ? (
      <div class="empty-state">Žádné akce zatím nejsou publikované.</div>
    ) : (
      list.map((item) => (
        <a class:list={["akce-item", !item.coverImageUrl && "akce-item-no-image"]} href={`/akce/${item.slug}`}>
          {
            item.coverImageUrl && (
              <img
                class="akce-img"
                src={item.coverImageUrl}
                alt={item.title}
                loading="lazy"
                decoding="async"
                referrerpolicy="no-referrer"
              />
            )
          }
          <h3 class="akce-name">{item.title}</h3>
          <div class="akce-date">{formatter.format(item.startsAt)}</div>
          <div class="akce-location">
            <span>{item.publicLocation}</span>
            <small>{item.accessType === "gated" ? "na kód" : item.source ? "import" : "veřejná"}</small>
          </div>
        </a>
      ))
    )}
  </div>
  <img src="/bunkr.png" class="bunkr" alt="Dekorativní bunkr" />
</section>

<style>
  .akce {
    position: relative;
    width: 100%;
    min-height: 100svh;
    margin: 0;
    display: flex;
    align-items: center;
    padding: clamp(24px, 4svh, 48px) 0;
    box-sizing: border-box;
    overflow: hidden;
  }
  .akce-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100svh;
    opacity: 0.02;
    background: url("/bg.jpeg");
    z-index: 0;
    background-size: cover;
  }
  .akce-title {
    font-size: 12rem;
    writing-mode: vertical-rl;
    text-orientation: upright;
  }
  .submit-link {
    position: absolute;
    z-index: 2;
    top: 24px;
    right: 24px;
    border: 2px solid #000;
    background: #fff6df;
    color: #000;
    padding: 9px 11px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 900;
  }
  .submit-link:hover {
    background: #000;
    color: #c00;
  }
  .akce-table {
    position: relative;
    z-index: 1;
    width: 70%;
    min-width: 0;
    max-height: min(78svh, 760px);
    min-height: 0;
    display: flex;
    flex-direction: column;
    margin: auto 40px;
    border: 3px solid black;
    background-color: #c00;
    overflow: auto;
    overflow-x: clip;
    overscroll-behavior: contain;
    scrollbar-color: #000 #c00;
  }
  .akce-item {
    width: 100%;
    box-sizing: border-box;
    min-width: 0;
    min-height: 80px;
    padding: 8px 18px;
    display: grid;
    grid-template-columns: 110px 1.5fr 1fr 1fr;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid black;
    font-size: 1.1rem;
    position: relative;
    cursor: pointer;
    text-decoration: none;
    color: black;
  }
  .akce-item-no-image {
    grid-template-columns: 1.5fr 1fr 1fr;
  }
  .akce-item:hover {
    color: #c00;
    background-color: #000;
  }
  .akce-img {
    max-width: 100px;
    height: 64px;
    object-fit: cover;
  }
  .akce-name {
    font-size: 1.7rem;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .akce-date,
  .akce-location {
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .akce-location {
    display: grid;
    gap: 3px;
  }
  .akce-location small {
    width: fit-content;
    border: 1px solid currentColor;
    padding: 2px 5px;
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 700;
  }
  .empty-state {
    padding: 24px;
    font-size: 1.4rem;
  }
  .bunkr {
    position: absolute;
    z-index: -1;
    bottom: -60px;
    right: -70px;
    width: 450px;
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .akce-title {
      font-size: 8rem;
    }
    .akce-table {
      width: 78%;
      margin: auto 20px;
    }
    .akce-item {
      grid-template-columns: 80px 1.2fr 1fr;
      gap: 10px;
    }
    .akce-item-no-image {
      grid-template-columns: 1.2fr 1fr;
    }
    .akce-location {
      display: none;
    }
    .akce-name {
      font-size: 1.4rem;
    }
    .akce-img {
      max-width: 72px;
      height: 52px;
    }
  }

  @media (max-width: 768px) {
    .akce {
      min-height: 100svh;
      display: grid;
      grid-template-rows: auto 1fr;
      align-items: stretch;
      gap: 10px;
      padding: 48px 10px 24px;
      overflow: hidden;
    }
    .akce-title {
      font-size: clamp(2.8rem, 18vw, 4.4rem);
      writing-mode: horizontal-tb;
      text-orientation: mixed;
      line-height: 0.9;
      padding: 0;
    }
    .submit-link {
      top: 10px;
      right: 10px;
      font-size: 0.7rem;
      padding: 7px 8px;
    }
    .akce-table {
      width: 100%;
      max-width: 100%;
      min-width: 0;
      margin: 0;
      box-sizing: border-box;
      max-height: calc(100svh - 130px);
    }
    .akce-item {
      grid-template-columns: 56px 1fr;
      grid-template-areas:
        "img name"
        "img date";
      min-height: 74px;
      padding: 10px 12px;
      gap: 4px 10px;
      font-size: 0.95rem;
    }
    .akce-item-no-image {
      grid-template-columns: 1fr;
      grid-template-areas:
        "name"
        "date";
    }
    .akce-img {
      grid-area: img;
      max-width: 52px;
      height: 44px;
    }
    .akce-name {
      grid-area: name;
      font-size: 1.05rem;
      line-height: 1.2;
    }
    .akce-date {
      grid-area: date;
      font-size: 0.85rem;
    }
    .bunkr {
      width: 210px;
      right: -24px;
      bottom: -30px;
      opacity: 0.55;
    }
  }
</style>
