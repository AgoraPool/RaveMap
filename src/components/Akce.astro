---
const {
  limit = 80,
  variant = "full",
} = Astro.props as { limit?: number; variant?: "full" | "preview" };
const isPreview = variant === "preview";
const cspNonce = Astro.locals.cspNonce;
---

<section class:list={["akce", isPreview && "akce-preview"]} id="akce" data-akce-root data-limit={limit} data-variant={variant}>
  <div class="akce-bg"></div>
  <div class="akce-actions">
    {!isPreview && <a class="home-link" href="/">Domů</a>}
    {!isPreview && <a class="map-link" href="/mapa">Mapa</a>}
    <a class="submit-link" href="/submit">Přidat akci</a>
    {isPreview && <a class="all-events-link" href="/akce">Všechny akce</a>}
  </div>
  <h2 class="akce-title">AKCE</h2>
  <div class="akce-table">
    <div class="loading-state" data-akce-loading>
      <strong>Načítám aktuální akce...</strong>
      <span>Čtu publikované RaveMap události z Nostr relayů.</span>
    </div>
    {!isPreview && (
      <div class="akce-sort-row" aria-label="Řazení akcí" hidden>
        <span class="akce-sort-spacer" aria-hidden="true"></span>
        <button type="button" data-sort-key="name" aria-label="Seřadit podle názvu">
          Název <span data-sort-indicator="name">-</span>
        </button>
        <button type="button" data-sort-key="date" aria-label="Seřadit podle data">
          Datum <span data-sort-indicator="date">↑</span>
        </button>
        <button type="button" data-sort-key="rsvp" aria-label="Seřadit podle účasti">
          Účast <span data-sort-indicator="rsvp">-</span>
        </button>
        <button type="button" data-sort-key="location" aria-label="Seřadit podle lokality">
          Lokalita <span data-sort-indicator="location">-</span>
        </button>
      </div>
    )}
    <div class="akce-list skeleton-list" data-akce-skeleton aria-hidden="true">
      {Array.from({ length: isPreview ? 4 : 7 }).map(() => (
        <article class="akce-item skeleton-row">
          <span class="akce-poster-cell skeleton-block"></span>
          <span class="skeleton-line wide"></span>
          <span class="skeleton-line"></span>
          {!isPreview && <span class="skeleton-line short"></span>}
          <span class="skeleton-line medium"></span>
        </article>
      ))}
    </div>
    <div class="akce-list" data-akce-list></div>
    <div class="empty-state" data-akce-empty hidden>Žádné akce zatím nejsou publikované.</div>
    <div class="empty-state" data-akce-error hidden>Akce se nepodařilo načíst. Zkus to prosím znovu.</div>
  </div>
  <img src="/bunkr.png" class="bunkr" alt="Dekorativní bunkr" />
</section>

<script nonce={cspNonce}>
{
  const root = document.querySelector("[data-akce-root]");
  const eventList = root?.querySelector("[data-akce-list]");
  const skeleton = root?.querySelector("[data-akce-skeleton]");
  const loading = root?.querySelector("[data-akce-loading]");
  const emptyState = root?.querySelector("[data-akce-empty]");
  const errorState = root?.querySelector("[data-akce-error]");
  const sortRow = root?.querySelector(".akce-sort-row");
  const sortButtons = [...(root?.querySelectorAll("[data-sort-key]") ?? [])];
  const sortIndicators = [...(root?.querySelectorAll("[data-sort-indicator]") ?? [])];
  const isPreview = root?.dataset.variant === "preview";
  const limit = Number(root?.dataset.limit || (isPreview ? 12 : 80));
  const collator = new Intl.Collator("cs-CZ", { sensitivity: "base", numeric: true });
  const formatter = new Intl.DateTimeFormat("cs-CZ", {
    dateStyle: "medium",
    timeStyle: "short",
  });
  const sortState = {
    key: "date",
    direction: "asc",
  };
  const cityOnlyLocations = new Set([
    "brno",
    "bratislava",
    "czech republic",
    "czechia",
    "cesko",
    "dresden",
    "germany",
    "ostrava",
    "plzen",
    "poland",
    "polsko",
    "praha",
    "prague",
    "rakousko",
    "slovakia",
    "slovensko",
    "vienna",
    "wien",
  ]);

  function normalizeLocation(value) {
    return String(value || "")
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .replace(/\s+/g, " ")
      .trim();
  }

  function hasPrecisePublicLocation(event) {
    const hasCoordinates = Number.isFinite(event.publicLatitude) && Number.isFinite(event.publicLongitude);
    const normalized = normalizeLocation(event.publicLocation);
    return hasCoordinates && normalized && !cityOnlyLocations.has(normalized);
  }

  function osmMarkerUrl(event, zoom = 16) {
    return `https://www.openstreetmap.org/?mlat=${event.publicLatitude}&mlon=${event.publicLongitude}#map=${zoom}/${event.publicLatitude}/${event.publicLongitude}`;
  }

  function provenance(event) {
    if (event.crewSlug || event.origin === "studio") return "crew";
    if (event.source || event.origin === "import") return "import";
    if (event.origin === "public" || event.tags?.includes("ravemap")) return "community";
    return "admin";
  }

  function provenanceLabel(value) {
    if (value === "crew") return "Crew";
    if (value === "community") return "Komunita";
    if (value === "import") return "Import";
    return "Admin";
  }

  function escapeHtml(value) {
    return String(value ?? "").replace(/[&<>"']/g, (character) => {
      if (character === "&") return "&amp;";
      if (character === "<") return "&lt;";
      if (character === ">") return "&gt;";
      if (character === '"') return "&quot;";
      return "&#39;";
    });
  }

  function renderEvent(event) {
    const startsAt = new Date(event.startsAt);
    const eventHref = `/akce/${encodeURIComponent(event.slug)}`;
    const mapHref = hasPrecisePublicLocation(event) ? osmMarkerUrl(event) : "";
    const eventProvenance = provenance(event);
    const poster = event.coverImageUrl
      ? `<img class="akce-img" src="${escapeHtml(event.coverImageUrl)}" alt="${escapeHtml(event.title)}" loading="lazy" decoding="async" referrerpolicy="no-referrer" />`
      : "";
    const rsvpCell = isPreview
      ? ""
      : `<div class="akce-rsvp" aria-label="Účast je dostupná v detailu akce"><strong>-</strong><small>účast v detailu</small></div>`;
    const crewLink = event.crewSlug && event.crewName ? `<a class="crew-link" href="/crew/${encodeURIComponent(event.crewSlug)}">${escapeHtml(event.crewName)}</a>` : "";
    const mapLink = mapHref
      ? `<a class="osm-link" href="${escapeHtml(mapHref)}" target="_blank" rel="noreferrer">OSM mapa</a>`
      : "";

    return `
      <article
        class="akce-item${mapHref ? " has-map" : ""}"
        data-name="${escapeHtml(String(event.title || "").toLocaleLowerCase("cs-CZ"))}"
        data-date="${startsAt.getTime()}"
        data-rsvp="0"
        data-location="${escapeHtml(String(event.publicLocation || "").toLocaleLowerCase("cs-CZ"))}"
      >
        <a class="akce-poster-cell" href="${eventHref}" aria-label="Otevřít akci ${escapeHtml(event.title)}">${poster}</a>
        <h3 class="akce-name"><a href="${eventHref}">${escapeHtml(event.title)}</a></h3>
        <div class="akce-date">${formatter.format(startsAt)}</div>
        ${rsvpCell}
        <div class="akce-location">
          <span>${escapeHtml(event.publicLocation)}</span>
          <div class="akce-location-actions">
            <small>${event.accessType === "gated" ? "na kód" : "veřejná"}</small>
            <small class="provenance-badge ${eventProvenance}">${provenanceLabel(eventProvenance)}</small>
            ${crewLink}
            ${mapLink}
          </div>
        </div>
      </article>
    `;
  }

  function setLoadingState(state) {
    if (loading instanceof HTMLElement) loading.hidden = state !== "loading";
    if (skeleton instanceof HTMLElement) skeleton.hidden = state !== "loading";
    if (emptyState instanceof HTMLElement) emptyState.hidden = state !== "empty";
    if (errorState instanceof HTMLElement) errorState.hidden = state !== "error";
    if (sortRow instanceof HTMLElement) sortRow.hidden = state !== "ready" || isPreview;
  }

  function valueFor(row, key) {
    if (!(row instanceof HTMLElement)) return "";
    if (key === "date") return Number(row.dataset.date || 0);
    if (key === "rsvp") return Number(row.dataset.rsvp || 0);
    if (key === "location") return row.dataset.location || "";
    return row.dataset.name || "";
  }

  function compareRows(left, right, key) {
    const leftValue = valueFor(left, key);
    const rightValue = valueFor(right, key);
    if (typeof leftValue === "number" && typeof rightValue === "number") {
      return leftValue - rightValue;
    }
    return collator.compare(String(leftValue), String(rightValue));
  }

  function renderSortState() {
    for (const indicator of sortIndicators) {
      if (!(indicator instanceof HTMLElement)) continue;
      indicator.textContent = indicator.dataset.sortIndicator === sortState.key ? (sortState.direction === "asc" ? "↑" : "↓") : "-";
    }

    for (const button of sortButtons) {
      if (!(button instanceof HTMLButtonElement)) continue;
      const active = button.dataset.sortKey === sortState.key;
      button.dataset.active = String(active);
      button.setAttribute("aria-sort", active ? (sortState.direction === "asc" ? "ascending" : "descending") : "none");
    }
  }

  function sortEvents(key) {
    if (!(eventList instanceof HTMLElement)) return;
    sortState.direction = sortState.key === key && sortState.direction === "asc" ? "desc" : "asc";
    sortState.key = key;

    const rows = [...eventList.querySelectorAll(".akce-item")];
    rows.sort((left, right) => {
      const result = compareRows(left, right, key);
      return sortState.direction === "asc" ? result : -result;
    });

    eventList.replaceChildren(...rows);
    renderSortState();
  }

  for (const button of sortButtons) {
    button.addEventListener("click", () => {
      if (!(button instanceof HTMLButtonElement) || !button.dataset.sortKey) return;
      sortEvents(button.dataset.sortKey);
    });
  }

  async function loadEvents() {
    if (!(eventList instanceof HTMLElement)) return;
    setLoadingState("loading");
    try {
      const response = await fetch(`/api/events?limit=${encodeURIComponent(String(limit))}`);
      const payload = await response.json();
      if (!response.ok || !payload?.ok) throw new Error(payload?.error?.message || "Akce nejsou dostupné");
      const events = Array.isArray(payload.data?.events) ? payload.data.events : [];
      eventList.innerHTML = events.map(renderEvent).join("");
      if (events.length === 0) {
        setLoadingState("empty");
        return;
      }
      setLoadingState("ready");
      renderSortState();
    } catch {
      eventList.innerHTML = "";
      setLoadingState("error");
    }
  }

  renderSortState();
  loadEvents();
}
</script>

<style>
  .akce {
    position: relative;
    width: 100%;
    min-height: 100svh;
    margin: 0;
    display: flex;
    align-items: center;
    padding: clamp(24px, 4svh, 48px) 0;
    box-sizing: border-box;
    overflow: hidden;
  }
  .akce-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100svh;
    opacity: 0.02;
    background: url("/bg.jpeg");
    z-index: 0;
    background-size: cover;
  }
  .akce-title {
    font-size: 12rem;
    writing-mode: vertical-rl;
    text-orientation: upright;
  }
  .akce-actions {
    position: absolute;
    z-index: 2;
    top: 24px;
    right: 24px;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
  }
  .submit-link,
  .all-events-link,
  .home-link,
  .map-link {
    border: 2px solid #000;
    background: #fff6df;
    color: #000;
    padding: 9px 11px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 900;
  }
  .all-events-link,
  .home-link,
  .map-link {
    background: #000;
    color: #c00;
  }
  .submit-link:hover,
  .all-events-link:hover,
  .home-link:hover,
  .map-link:hover {
    background: #000;
    color: #c00;
  }
  .all-events-link:hover,
  .home-link:hover,
  .map-link:hover {
    background: #fff6df;
    color: #000;
  }
  .akce-table {
    position: relative;
    z-index: 1;
    width: 70%;
    min-width: 0;
    max-height: min(78svh, 760px);
    min-height: 0;
    display: flex;
    flex-direction: column;
    margin: auto 40px;
    border: 3px solid black;
    background-color: #c00;
    overflow: auto;
    overflow-x: clip;
    overscroll-behavior: contain;
    scrollbar-color: #000 #c00;
  }

  .promo-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 14px;
    margin-bottom: 14px;
    border: 1px solid rgba(240, 207, 101, 0.35);
    border-radius: 8px;
    background: rgba(240, 207, 101, 0.08);
  }

  .promo-strip span,
  .promo-strip small {
    display: block;
    color: rgba(244, 240, 232, 0.72);
  }

  .promo-strip a,
  .crew-link {
    color: #f0cf65;
  }
  .akce-sort-row,
  .akce-item {
    width: 100%;
    box-sizing: border-box;
    min-width: 0;
    display: grid;
    grid-template-columns: 110px minmax(0, 1.45fr) minmax(130px, 0.9fr) minmax(92px, 0.55fr) minmax(140px, 0.9fr);
    align-items: center;
    gap: 16px;
  }
  .akce-sort-row {
    position: sticky;
    top: 0;
    z-index: 3;
    padding: 8px 18px;
    border-bottom: 3px solid black;
    background: #000;
  }
  .akce-sort-row button {
    min-width: 0;
    width: 100%;
    border: 2px solid #fff6df;
    background: #c00;
    color: #fff6df;
    padding: 7px 8px;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: left;
    cursor: pointer;
  }
  .akce-sort-row button:hover,
  .akce-sort-row button[data-active="true"] {
    background: #fff6df;
    color: #000;
  }
  .akce-list {
    display: contents;
  }
  .akce-item {
    min-height: 80px;
    padding: 8px 18px;
    border-bottom: 1px solid black;
    font-size: 1.1rem;
    position: relative;
    color: black;
  }
  .akce-item:hover {
    color: #c00;
    background-color: #000;
  }
  .akce-poster-cell {
    width: 100px;
    height: 64px;
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .akce-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .akce-name {
    font-size: 1.7rem;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .akce-name a {
    color: inherit;
    text-decoration: none;
  }
  .akce-name a:hover,
  .akce-name a:focus-visible {
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 4px;
  }
  .akce-date,
  .akce-rsvp,
  .akce-location {
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .akce-rsvp {
    display: grid;
    gap: 3px;
  }
  .akce-rsvp strong {
    font-size: 1.45rem;
    line-height: 1;
  }
  .akce-rsvp small {
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.2;
  }
  .akce-rsvp .akce-signal {
    width: fit-content;
    border: 1px solid currentColor;
    padding: 2px 5px;
  }
  .akce-location {
    display: grid;
    gap: 3px;
  }
  .akce-location-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    align-items: center;
  }
  .akce-location small,
  .osm-link {
    width: fit-content;
    border: 1px solid currentColor;
    padding: 2px 5px;
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1.1;
  }
  .akce-location-actions .provenance-badge {
    background: #e5e7eb;
    color: #000;
  }
  .akce-location-actions .provenance-badge.crew {
    background: #bbf7d0;
  }
  .akce-location-actions .provenance-badge.community {
    background: #dbeafe;
  }
  .akce-location-actions .provenance-badge.import {
    background: #fde68a;
  }
  .osm-link {
    background: #fff6df;
    color: #000;
    text-decoration: none;
  }
  .osm-link:hover,
  .osm-link:focus-visible {
    background: #000;
    color: #c00;
  }
  .akce-preview {
    align-items: stretch;
    padding-top: 64px;
    overflow: visible;
  }
  .akce-preview .akce-table {
    width: min(1040px, 76%);
    max-height: none;
    overflow: visible;
  }
  .akce-preview .akce-list {
    display: block;
  }
  .akce-preview .akce-item {
    grid-template-columns: 96px minmax(0, 1.5fr) minmax(150px, 0.7fr) minmax(150px, 0.8fr);
    min-height: 88px;
    border-bottom-width: 2px;
  }
  .akce-preview .akce-item:last-child {
    border-bottom: 0;
  }
  .akce-preview .akce-name {
    font-size: 1.95rem;
    line-height: 0.95;
  }
  .akce-preview .akce-date {
    font-weight: 700;
  }
  .empty-state {
    padding: 24px;
    font-size: 1.4rem;
  }
  .loading-state {
    display: grid;
    gap: 4px;
    padding: 18px;
    border-bottom: 3px solid #000;
    background: #000;
    color: #fff6df;
  }
  .loading-state strong {
    font-size: 1.1rem;
    text-transform: uppercase;
  }
  .loading-state span {
    color: rgba(255, 246, 223, 0.78);
    font-size: 0.86rem;
    font-weight: 700;
  }
  .loading-state[hidden],
  .empty-state[hidden],
  .akce-sort-row[hidden],
  .skeleton-list[hidden] {
    display: none;
  }
  .skeleton-row {
    pointer-events: none;
  }
  .skeleton-block,
  .skeleton-line {
    display: block;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.3), rgba(255, 246, 223, 0.45), rgba(0, 0, 0, 0.3));
    background-size: 220% 100%;
    animation: skeleton-pulse 1.2s ease-in-out infinite;
  }
  .skeleton-line {
    width: 72%;
    height: 16px;
  }
  .skeleton-line.wide {
    width: 92%;
    height: 24px;
  }
  .skeleton-line.medium {
    width: 58%;
  }
  .skeleton-line.short {
    width: 36%;
  }
  @keyframes skeleton-pulse {
    from {
      background-position: 100% 0;
    }
    to {
      background-position: -100% 0;
    }
  }
  :global(.akce [data-akce-list]) {
    display: contents;
  }
  :global(.akce [data-akce-list] .akce-item) {
    width: 100%;
    box-sizing: border-box;
    min-width: 0;
    min-height: 80px;
    display: grid;
    grid-template-columns: 110px minmax(0, 1.45fr) minmax(130px, 0.9fr) minmax(92px, 0.55fr) minmax(140px, 0.9fr);
    align-items: center;
    gap: 16px;
    padding: 8px 18px;
    border-bottom: 1px solid black;
    font-size: 1.1rem;
    position: relative;
    color: black;
  }
  :global(.akce [data-akce-list] .akce-item:hover) {
    color: #c00;
    background-color: #000;
  }
  :global(.akce [data-akce-list] .akce-poster-cell) {
    width: 100px;
    height: 64px;
    display: block;
    color: inherit;
    text-decoration: none;
    background: rgba(0, 0, 0, 0.16);
  }
  :global(.akce [data-akce-list] .akce-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  :global(.akce [data-akce-list] .akce-name) {
    margin: 0;
    font-size: 1.7rem;
    min-width: 0;
    overflow-wrap: anywhere;
    line-height: 0.95;
  }
  :global(.akce [data-akce-list] .akce-name a) {
    color: inherit;
    text-decoration: none;
  }
  :global(.akce [data-akce-list] .akce-name a:hover),
  :global(.akce [data-akce-list] .akce-name a:focus-visible) {
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 4px;
  }
  :global(.akce [data-akce-list] .akce-date),
  :global(.akce [data-akce-list] .akce-rsvp),
  :global(.akce [data-akce-list] .akce-location) {
    min-width: 0;
    overflow-wrap: anywhere;
  }
  :global(.akce [data-akce-list] .akce-rsvp) {
    display: grid;
    gap: 3px;
  }
  :global(.akce [data-akce-list] .akce-rsvp strong) {
    font-size: 1.45rem;
    line-height: 1;
  }
  :global(.akce [data-akce-list] .akce-rsvp small) {
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.2;
  }
  :global(.akce [data-akce-list] .akce-location) {
    display: grid;
    gap: 3px;
  }
  :global(.akce [data-akce-list] .akce-location-actions) {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    align-items: center;
  }
  :global(.akce [data-akce-list] .akce-location small),
  :global(.akce [data-akce-list] .osm-link) {
    width: fit-content;
    border: 1px solid currentColor;
    padding: 2px 5px;
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1.1;
  }
  :global(.akce [data-akce-list] .provenance-badge) {
    background: #e5e7eb;
    color: #000;
  }
  :global(.akce [data-akce-list] .provenance-badge.crew) {
    background: #bbf7d0;
  }
  :global(.akce [data-akce-list] .provenance-badge.community) {
    background: #dbeafe;
  }
  :global(.akce [data-akce-list] .provenance-badge.import) {
