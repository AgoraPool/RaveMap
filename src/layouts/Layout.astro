---
import "../styles/global.css";

const { bodyClass = "" } = Astro.props;
const showGridCanvas = !bodyClass.split(/\s+/).includes("admin-body");
const htmlClass = bodyClass.split(/\s+/).includes("admin-body") ? "admin-html" : "";
---

<!doctype html>
<html lang="cs" class={htmlClass}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/bunkr.png" />
		<link rel="icon" href="/bunkr.png" />
		<meta name="generator" content={Astro.generator} />
		<title>Kam Na Rave</title>

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
		href="https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Space+Grotesk:wght@400;500;600;700&display=swap"
		rel="stylesheet"
		/>
	</head>
	<body class={bodyClass}>
		{
			showGridCanvas && (
				<div class="grid-canvas">
					<span class="v" style="--x: 8svw;  --w: 3px;"></span>
					<span class="v" style="--x: 27svw; --w: 3px;"></span>
					<span class="v" style="--x: 63svw; --w: 3px;"></span>
					<span class="v" style="--x: 68%; --w: 3px;"></span>
					<span class="v" style="--x: 88%; --w: 3px;"></span>

					<span class="h" style="--y: 8%; --w: 3px;"></span>
					<span class="h" style="--y: 14%; --w: 3px;"></span>
					<span class="h" style="--y: 23%; --w: 3px;"></span>
					<span class="h" style="--y: 24%; --w: 3px;"></span>
					<span class="h" style="--y: 46%; --w: 3px;"></span>
					<span class="h" style="--y: 50%; --w: 3px;"></span>
					<span class="h" style="--y: 58%; --w: 3px;"></span>
					<span class="h" style="--y: 68%; --w: 3px;"></span>
					<span class="h" style="--y: 74%; --w: 3px;"></span>
					<span class="h" style="--y: 75%; --w: 3px;"></span>
					<span class="h" style="--y: 88%; --w: 3px;"></span>
					<span class="h" style="--y: 96%; --w: 3px;"></span>
	    		</div>
			)
		}
		<slot />
	</body>
</html>

{
	showGridCanvas && (
		<script>
			const sections = [...document.querySelectorAll("body.home-body section")];
			const mobileQuery = window.matchMedia("(max-width: 768px)");
			const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
			let frame = 0;

			function clamp(v, a, b) {
			  return Math.max(a, Math.min(b, v));
			}

			function easeOutCubic(v) {
			  return 1 - Math.pow(1 - v, 3);
			}

			function resetSectionEffects() {
			  for (const s of sections) {
			    s.style.transform = "";
			    s.style.opacity = "";
			  }
			}

			function update() {
			  frame = 0;

			  if (mobileQuery.matches || reducedMotionQuery.matches || sections.length === 0) {
			    resetSectionEffects();
			    return;
			  }

			  const vh = window.innerHeight;
			  const vc = vh / 2;

			  for (const s of sections) {
			    const r = s.getBoundingClientRect();
			    const sc = r.top + r.height / 2;
			    const t = clamp((sc - vc) / Math.max(vh, 1), -1, 1);
			    const distance = Math.abs(t);
			    const eased = easeOutCubic(distance);

			    const rotY = -t * 6;
			    const z = -eased * 34;
			    const y = -t * 8;
			    const scale = 1 - eased * 0.018;
			    const opacity = 1 - eased * 0.08;

			    s.style.transform = `translate3d(0, ${y}px, ${z}px) rotateY(${rotY}deg) scale(${scale})`;
			    s.style.opacity = opacity;
			  }
			}

			function scheduleUpdate() {
			  if (frame) {
			    return;
			  }

			  frame = requestAnimationFrame(update);
			}

			if (sections.length > 0) {
			  window.addEventListener("scroll", scheduleUpdate, { passive: true });
			  window.addEventListener("resize", scheduleUpdate);
			  mobileQuery.addEventListener("change", scheduleUpdate);
			  reducedMotionQuery.addEventListener("change", scheduleUpdate);
			  update();
			}
		</script>
	)
}
