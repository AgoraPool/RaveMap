---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getNostrEventRepository } from "../../lib/server/nostr-repository";

const slug = Astro.params.slug?.trim().toLowerCase() ?? "";
const repository = getNostrEventRepository();
const cspNonce = Astro.locals.cspNonce;
const crew = /^[a-z0-9-]{3,120}$/.test(slug) ? await repository.getCrewProfile(slug) : null;
const promo = crew?.lightningAddress ? await repository.getPromoZapSummary("crew", crew.slug).catch(() => null) : null;

if (!crew) {
  Astro.response.status = 404;
}
---

<Layout bodyClass="crew-body">
  <main class="crew-shell" data-crew-detail data-crew-slug={crew?.slug ?? ""}>
    <nav class="crew-nav">
      <a href="/crew">Crew</a>
      <a href="/akce">Akce</a>
    </nav>
    {
      !crew ? (
        <section class="crew-hero">
          <h1>Crew nenalezena</h1>
          <p>Tenhle crew profil neexistuje nebo je archivovaný.</p>
        </section>
      ) : (
        <>
          <section class="crew-hero">
            {crew.bannerUrl ? <img class="crew-banner" src={crew.bannerUrl} alt="" loading="eager" decoding="async" referrerpolicy="no-referrer" /> : null}
            <div class="crew-title-row">
              {
                crew.avatarUrl ? (
                  <img class="crew-avatar" src={crew.avatarUrl} alt={crew.name} loading="eager" decoding="async" referrerpolicy="no-referrer" />
                ) : (
                  <span class="crew-avatar crew-avatar-placeholder" aria-hidden="true">{crew.name.slice(0, 1)}</span>
                )
              }
              <div>
                <p class="kicker">Crew</p>
                <h1>{crew.name}</h1>
              </div>
            </div>
            {crew.summary ? <p class="crew-summary">{crew.summary}</p> : null}
            <div class="crew-actions">
              {crew.websiteUrl ? <a href={crew.websiteUrl} target="_blank" rel="noreferrer">Web</a> : null}
              {crew.simplexUrl ? <a href={crew.simplexUrl} target="_blank" rel="noreferrer">SimpleX</a> : null}
              {crew.lightningAddress ? <button type="button" data-zap-button data-target-type="crew" data-slug={crew.slug}>Zap promo</button> : null}
            </div>
            {promo && promo.score > 0 ? <p class="promo-line">{promo.receipts} promo zapů za posledních 14 dní</p> : null}
          </section>

          <section class="event-section">
            <h2>Další akce</h2>
            <p class="empty-state" data-crew-loading>Načítám aktuální akce...</p>
            <div class="event-list" data-crew-upcoming></div>
            <p class="empty-state" data-crew-empty hidden>Tahle crew zatím nemá publikovanou další akci.</p>
            <p class="empty-state" data-crew-error hidden>Akce crew se nepodařilo načíst.</p>
          </section>

          <section class="event-section" data-crew-past-section hidden>
            <h2>Historie</h2>
            <div class="event-list compact" data-crew-past>
            </div>
          </section>
        </>
      )
    }
  </main>
</Layout>

<script nonce={cspNonce}>
{
  const crewRoot = document.querySelector("[data-crew-detail]");
  const crewSlug = crewRoot?.dataset.crewSlug || "";
  const crewLoading = document.querySelector("[data-crew-loading]");
  const crewUpcoming = document.querySelector("[data-crew-upcoming]");
  const crewEmpty = document.querySelector("[data-crew-empty]");
  const crewError = document.querySelector("[data-crew-error]");
  const crewPastSection = document.querySelector("[data-crew-past-section]");
  const crewPast = document.querySelector("[data-crew-past]");
  const crewFormatter = new Intl.DateTimeFormat("cs-CZ", {
    dateStyle: "medium",
    timeStyle: "short",
  });

  function escapeHtml(value) {
    return String(value ?? "").replace(/[&<>"']/g, (character) => {
      if (character === "&") return "&amp;";
      if (character === "<") return "&lt;";
      if (character === ">") return "&gt;";
      if (character === '"') return "&quot;";
      return "&#39;";
    });
  }

  function eventRow(event, compact = false) {
    return `
      <a class="event-row" href="/akce/${encodeURIComponent(event.slug)}">
        <strong>${escapeHtml(event.title)}</strong>
        <span>${crewFormatter.format(new Date(event.startsAt))}</span>
        ${compact ? "" : `<small>${escapeHtml(event.publicLocation)}</small>`}
      </a>
    `;
  }

  function setCrewEventState(state) {
    if (crewLoading instanceof HTMLElement) crewLoading.hidden = state !== "loading";
    if (crewEmpty instanceof HTMLElement) crewEmpty.hidden = state !== "empty";
    if (crewError instanceof HTMLElement) crewError.hidden = state !== "error";
  }

  async function loadCrewEvents() {
    if (!crewSlug || !(crewUpcoming instanceof HTMLElement)) return;
    setCrewEventState("loading");
    try {
      const response = await fetch(`/api/crews/${encodeURIComponent(crewSlug)}`);
      const payload = await response.json();
      if (!response.ok || !payload?.ok) throw new Error(payload?.error?.message || "Crew akce nejsou dostupné");
      const now = Date.now();
      const events = Array.isArray(payload.data?.events) ? payload.data.events : [];
      const upcoming = events
        .filter((event) => new Date(event.startsAt).getTime() >= now)
        .sort((left, right) => new Date(left.startsAt).getTime() - new Date(right.startsAt).getTime());
      const past = events
        .filter((event) => new Date(event.startsAt).getTime() < now)
        .sort((left, right) => new Date(right.startsAt).getTime() - new Date(left.startsAt).getTime());

      crewUpcoming.innerHTML = upcoming.map((event) => eventRow(event)).join("");
      if (crewPast instanceof HTMLElement) {
        crewPast.innerHTML = past.slice(0, 12).map((event) => eventRow(event, true)).join("");
      }
      if (crewPastSection instanceof HTMLElement) {
        crewPastSection.hidden = past.length === 0;
      }
      setCrewEventState(upcoming.length === 0 ? "empty" : "ready");
    } catch {
      if (crewUpcoming instanceof HTMLElement) crewUpcoming.innerHTML = "";
      if (crewPastSection instanceof HTMLElement) crewPastSection.hidden = true;
      setCrewEventState("error");
    }
  }

  loadCrewEvents();

  async function requestPromoInvoice(button) {
    if (!(button instanceof HTMLButtonElement)) return;
    const amount = Number(window.prompt("Kolik sats poslat na promo?", "210"));
    if (!Number.isInteger(amount) || amount < 21) return;
    button.disabled = true;
    const original = button.textContent;
    button.textContent = "Vytvářím fakturu";
    try {
      const response = await fetch("/api/zaps/promo-invoice", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          targetType: button.dataset.targetType,
          slug: button.dataset.slug,
          amountSats: amount,
        }),
      });
      const payload = await response.json();
      if (!response.ok || !payload?.ok) throw new Error(payload.error?.message || "Faktura není dostupná");
      await navigator.clipboard.writeText(payload.data.invoice);
      button.textContent = "Faktura zkopírována";
    } catch (error) {
      button.textContent = error instanceof Error ? error.message : "Chyba";
    } finally {
      window.setTimeout(() => {
        button.disabled = false;
        button.textContent = original;
      }, 2200);
    }
  }

  for (const button of document.querySelectorAll("[data-zap-button]")) {
    button.addEventListener("click", () => requestPromoInvoice(button));
  }
}
</script>

<style>
  .crew-shell {
    position: relative;
    min-height: 100svh;
    padding: clamp(18px, 4vw, 42px);
    color: #000;
    background: #c00;
    box-sizing: border-box;
    overflow: hidden;
  }

  .crew-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("/bg.jpeg") center / cover;
    opacity: 0.035;
    pointer-events: none;
  }

  .crew-nav,
  .crew-hero,
  .event-section {
    position: relative;
    z-index: 1;
  }

  .crew-nav,
  .crew-actions,
  .crew-title-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .crew-nav {
    justify-content: flex-end;
  }

  .crew-nav a,
  .crew-actions a,
  .crew-actions button {
    border: 2px solid #000;
    background: #fff6df;
    color: #000;
    padding: 9px 11px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 900;
    font-family: var(--font-body);
    cursor: pointer;
  }

  .crew-nav a:last-child,
  .crew-actions button {
    background: #000;
    color: #c00;
  }

  .crew-nav a:hover,
  .crew-actions a:hover,
  .crew-actions button:hover,
  .event-row:hover {
    background: #000;
    color: #c00;
  }

  .crew-hero,
  .event-section {
    max-width: 980px;
    margin: 22px auto;
    border: 3px solid #000;
    background: rgba(255, 246, 223, 0.96);
    box-shadow: 10px 10px 0 #000;
    padding: clamp(16px, 4vw, 28px);
  }

  .crew-hero {
    display: grid;
    gap: 18px;
    margin-top: clamp(42px, 7vw, 76px);
  }

  .crew-banner {
    width: 100%;
    aspect-ratio: 16 / 5;
    max-height: 300px;
    object-fit: cover;
    border: 3px solid #000;
    background: #fff6df;
  }

  .crew-title-row {
    align-items: center;
  }

  .crew-avatar {
    width: clamp(76px, 12vw, 112px);
    height: clamp(76px, 12vw, 112px);
    object-fit: cover;
    border: 3px solid #000;
    background: #c00;
    flex: 0 0 auto;
  }

  .crew-avatar-placeholder {
    display: grid;
    place-items: center;
    color: #000;
    font-size: clamp(2rem, 7vw, 4rem);
    font-weight: 900;
    text-transform: uppercase;
  }

  .kicker {
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 900;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 10vw, 8rem);
    line-height: 0.86;
    overflow-wrap: anywhere;
  }

  h2 {
    margin: 0 0 14px;
    font-size: clamp(1.8rem, 5vw, 3.8rem);
    line-height: 0.92;
  }

  .crew-summary {
    max-width: 720px;
    line-height: 1.55;
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 650;
  }

  .promo-line,
  .empty-state {
    font-weight: 900;
  }

  .promo-line {
    border-left: 6px solid #000;
    padding-left: 12px;
  }

  .event-list {
    display: grid;
    gap: 8px;
  }

  .event-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 12px;
    align-items: center;
    padding: 12px 14px;
    border: 2px solid #000;
    background: #fffef8;
    color: #000;
    text-decoration: none;
  }

  .event-row strong {
    overflow-wrap: anywhere;
  }

  .event-row span,
  .event-row small {
    font-weight: 800;
  }

  .event-row small {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.74rem;
  }

  .empty-state {
    border: 2px solid #000;
    background: #fffef8;
    padding: 14px;
  }

  .event-section[hidden],
  .empty-state[hidden] {
    display: none;
  }

  @media (max-width: 760px) {
    .crew-shell {
      padding: 14px;
    }

    .crew-nav {
      justify-content: flex-start;
    }

    .crew-title-row {
      align-items: flex-start;
    }

    .crew-banner {
      aspect-ratio: 4 / 3;
    }

    .event-row {
      grid-template-columns: 1fr;
    }
  }
</style>
