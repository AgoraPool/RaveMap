---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getNostrEventRepository } from "../../lib/server/nostr-repository";

const repository = getNostrEventRepository();
const crews = await repository.listCrewProfiles();
---

<Layout bodyClass="crew-body">
  <main class="crew-shell">
    <nav class="crew-nav">
      <a href="/akce">Akce</a>
      <a href="/studio">Studio</a>
      <a href="/">Domů</a>
    </nav>
    <section class="crew-header">
      <p class="kicker">Crew</p>
      <h1>Pořadatelé</h1>
    </section>
    <section class="crew-list">
      {
        crews.length === 0 ? (
          <p class="empty-state">Zatím tu nejsou žádné veřejné crew profily.</p>
        ) : (
          crews.map((crew) => (
            <a class="crew-card" href={`/crew/${crew.slug}`}>
              {
                crew.avatarUrl ? (
                  <img src={crew.avatarUrl} alt={crew.name} loading="lazy" decoding="async" referrerpolicy="no-referrer" />
                ) : (
                  <span class="crew-avatar-placeholder" aria-hidden="true">{crew.name.slice(0, 1)}</span>
                )
              }
              <div>
                <strong>{crew.name}</strong>
                {crew.summary ? <p>{crew.summary}</p> : null}
                <small>{crew.lightningAddress ? "zap promo ready" : crew.simplexUrl ? "SimpleX kontakt" : "crew profil"}</small>
              </div>
            </a>
          ))
        )
      }
    </section>
  </main>
</Layout>

<style>
  .crew-shell {
    position: relative;
    min-height: 100svh;
    padding: clamp(18px, 4vw, 42px);
    color: #000;
    background: #c00;
    box-sizing: border-box;
    overflow: hidden;
  }

  .crew-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("/bg.jpeg") center / cover;
    opacity: 0.035;
    pointer-events: none;
  }

  .crew-nav,
  .crew-header,
  .crew-list {
    position: relative;
    z-index: 1;
  }

  .crew-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .crew-nav a {
    border: 2px solid #000;
    background: #000;
    color: #c00;
    padding: 9px 11px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 900;
  }

  .crew-nav a:first-child {
    background: #fff6df;
    color: #000;
  }

  .crew-nav a:hover,
  .crew-card:hover {
    background: #000;
    color: #c00;
  }

  .crew-header {
    max-width: 960px;
    margin: clamp(42px, 8vw, 92px) auto 22px;
    border: 3px solid #000;
    background: rgba(255, 246, 223, 0.96);
    box-shadow: 10px 10px 0 #000;
    padding: clamp(16px, 4vw, 28px);
  }

  .kicker {
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 900;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 10vw, 8rem);
    line-height: 0.86;
  }

  .crew-list {
    display: grid;
    gap: 10px;
    max-width: 960px;
    margin: 0 auto;
  }

  .crew-card {
    display: grid;
    grid-template-columns: 82px minmax(0, 1fr) auto;
    align-items: center;
    gap: 14px;
    padding: 14px;
    border: 3px solid #000;
    background: rgba(255, 246, 223, 0.96);
    color: #000;
    box-shadow: 6px 6px 0 #000;
    text-decoration: none;
    transition:
      transform 120ms ease,
      box-shadow 120ms ease,
      background 120ms ease;
  }

  .crew-card:hover {
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 #000;
  }

  .crew-card img,
  .crew-avatar-placeholder {
    width: 82px;
    height: 82px;
    border: 2px solid #000;
  }

  .crew-card img {
    object-fit: cover;
    background: #fff6df;
  }

  .crew-avatar-placeholder {
    display: grid;
    place-items: center;
    background: #c00;
    color: #000;
    font-size: 2rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .crew-card > div {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .crew-card strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3vw, 2.2rem);
    line-height: 0.95;
    overflow-wrap: anywhere;
  }

  .crew-card::after {
    content: "Otevřít";
    border: 2px solid currentColor;
    padding: 8px 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.76rem;
    font-weight: 900;
  }

  .crew-card p {
    margin: 0;
    line-height: 1.45;
    font-weight: 600;
  }

  .crew-card small,
  .empty-state {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.74rem;
    font-weight: 900;
  }

  .empty-state {
    border: 3px solid #000;
    background: #fff6df;
    padding: 18px;
    box-shadow: 6px 6px 0 #000;
  }

  @media (max-width: 720px) {
    .crew-shell {
      padding: 14px;
    }

    .crew-nav {
      justify-content: flex-start;
    }

    .crew-card {
      grid-template-columns: 64px minmax(0, 1fr);
    }

    .crew-card img,
    .crew-avatar-placeholder {
      width: 64px;
      height: 64px;
    }

    .crew-card::after {
      grid-column: 1 / -1;
      text-align: center;
    }
  }
</style>
