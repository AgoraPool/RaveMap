---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getNostrEventRepository } from "../../lib/server/nostr-repository";

const repository = getNostrEventRepository();
const crews = await repository.listCrewProfiles();
---

<Layout bodyClass="crew-body">
  <main class="crew-shell">
    <nav class="crew-nav">
      <a href="/akce">Akce</a>
      <a href="/">Domů</a>
    </nav>
    <section class="crew-header">
      <p class="kicker">Crew</p>
      <h1>Pořadatelé</h1>
    </section>
    <section class="crew-list">
      {
        crews.length === 0 ? (
          <p class="empty-state">Zatím tu nejsou žádné veřejné crew profily.</p>
        ) : (
          crews.map((crew) => (
            <a class="crew-card" href={`/crew/${crew.slug}`}>
              {
                crew.avatarUrl ? (
                  <img src={crew.avatarUrl} alt={crew.name} loading="lazy" decoding="async" referrerpolicy="no-referrer" />
                ) : (
                  <span class="crew-avatar-placeholder" aria-hidden="true">{crew.name.slice(0, 1)}</span>
                )
              }
              <div>
                <strong>{crew.name}</strong>
                {crew.summary ? <p>{crew.summary}</p> : null}
                <small>{crew.lightningAddress ? "zap promo ready" : crew.simplexUrl ? "SimpleX kontakt" : "crew profil"}</small>
              </div>
            </a>
          ))
        )
      }
    </section>
  </main>
</Layout>

<style>
  .crew-shell {
    min-height: 100svh;
    padding: 24px;
    color: #f4f0e8;
    background: #101010;
  }

  .crew-nav {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }

  .crew-nav a,
  .crew-card {
    color: inherit;
    text-decoration: none;
  }

  .crew-header {
    max-width: 960px;
    margin: 48px auto 24px;
  }

  .kicker {
    margin: 0 0 8px;
    color: #f0cf65;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 8vw, 6rem);
  }

  .crew-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    max-width: 960px;
    margin: 0 auto;
  }

  .crew-card {
    display: grid;
    grid-template-columns: 74px 1fr;
    gap: 14px;
    padding: 14px;
    border: 1px solid rgba(244, 240, 232, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
  }

  .crew-card img,
  .crew-avatar-placeholder {
    width: 74px;
    height: 74px;
    border-radius: 8px;
  }

  .crew-card img {
    object-fit: cover;
  }

  .crew-avatar-placeholder {
    display: grid;
    place-items: center;
    border: 1px solid rgba(244, 240, 232, 0.18);
    background: #c00;
    color: #fff6df;
    font-size: 2rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .crew-card strong {
    display: block;
    margin-bottom: 6px;
    font-size: 1.1rem;
  }

  .crew-card p,
  .crew-card small,
  .empty-state {
    color: rgba(244, 240, 232, 0.72);
  }

  .crew-card p {
    margin: 0 0 10px;
    line-height: 1.45;
  }
</style>
