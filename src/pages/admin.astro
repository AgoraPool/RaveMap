---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
---

<Layout bodyClass="admin-body">
  <main class="admin-shell">
    <section id="access-gate" class="access-gate">
      <div class="gate-card">
        <p class="kicker">Admin přístup</p>
        <h1>RaveMap řízení</h1>
        <p class="gate-copy">Nostr operace zůstanou skryté, dokud neověříš admin kód.</p>

        <form id="access-form" class="access-form">
          <input id="adminSecret" name="adminSecret" type="password" minlength="24" placeholder="Admin kód" required />
          <button id="unlock-button" type="submit">Odemknout</button>
        </form>

        <p id="auth-status" class="status-line neutral">Zadej admin kód pro otevření kokpitu.</p>
      </div>
    </section>

    <section id="workspace" class="workspace" hidden>
      <header class="admin-topbar">
        <div>
          <p class="kicker">Nostr kokpit</p>
          <h1>RaveMap Admin</h1>
        </div>
        <p class="topbar-note">Podepsané publikování na relaye. Veřejné a kódem zamčené akce.</p>
      </header>

      <section class="status-grid">
        <div class="metric">
          <span>Přístup</span>
          <strong id="auth-state">Zamčeno</strong>
        </div>
        <div class="metric">
          <span>Akce</span>
          <strong id="event-count">0</strong>
        </div>
        <div class="metric">
          <span>Relaye</span>
          <strong id="relay-state">Nezkontrolováno</strong>
        </div>
        <div class="metric">
          <span>Import</span>
          <strong id="import-state">Čeká</strong>
        </div>
      </section>

      <p id="global-status" class="status-line neutral">Pracovní plocha načtena.</p>

      <div class="cockpit-grid">
        <div class="panel form-panel">
          <div class="panel-head">
            <div>
              <p class="kicker">Úpravy</p>
              <h2>Vytvořit nebo upravit akci</h2>
            </div>
            <button id="reset-form" type="button">Nová</button>
          </div>

          <form id="event-form" class="event-form">
            <input id="slug" name="slug" type="hidden" />

            <div class="editor-mode-row">
              <div class="segmented" role="group" aria-label="Typ přístupu k akci">
                <label>
                  <input type="radio" name="accessType" value="public" checked />
                  <span>Veřejná</span>
                </label>
                <label>
                  <input type="radio" name="accessType" value="gated" />
                  <span>Na kód</span>
                </label>
              </div>

              <label class="publish-check">
                <input id="isPublished" name="isPublished" type="checkbox" />
                <span>Publikovat</span>
              </label>
            </div>

            <fieldset class="form-section">
              <legend>Základ</legend>
              <label class="title-field">
                <span>Název</span>
                <input id="title" name="title" type="text" minlength="3" maxlength="180" required />
              </label>

              <div class="field-row">
                <label>
                  <span>Začátek</span>
                  <input id="startsAt" name="startsAt" type="datetime-local" required />
                </label>
                <label>
                  <span>Konec</span>
                  <input id="endAt" name="endAt" type="datetime-local" />
                </label>
              </div>

              <label>
                <span>Veřejná lokalita</span>
                <input id="publicLocation" name="publicLocation" type="text" minlength="2" maxlength="180" required />
              </label>
              <div class="field-row">
                <label>
                  <span>Veřejná šířka</span>
                  <input id="publicLatitude" name="publicLatitude" type="number" step="0.000001" min="-90" max="90" />
                </label>
                <label>
                  <span>Veřejná délka</span>
                  <input id="publicLongitude" name="publicLongitude" type="number" step="0.000001" min="-180" max="180" />
                </label>
              </div>
            </fieldset>

            <fieldset class="form-section">
              <legend>Veřejný obsah</legend>
              <label>
                <span>Popis</span>
                <textarea id="summary" name="summary" minlength="10" maxlength="2000" required></textarea>
              </label>

              <div class="field-row">
                <label>
                  <span>Žánry</span>
                  <input id="genres" name="genres" type="text" placeholder="tekno, freetekno" />
                </label>
                <label>
                  <span>Lineup</span>
                  <input id="lineup" name="lineup" type="text" placeholder="umělec, crew" />
                </label>
              </div>

              <label>
                <span>URL plakátu</span>
                <input id="coverImageUrl" name="coverImageUrl" type="url" inputmode="url" placeholder="https://..." />
              </label>
            </fieldset>

            <fieldset class="form-section">
              <legend>Zdroj</legend>
              <div class="field-row">
                <label>
                  <span>Externí URL</span>
                  <input id="externalUrl" name="externalUrl" type="url" inputmode="url" placeholder="https://..." />
                </label>
                <label>
                  <span>URL zdroje</span>
                  <input id="sourceUrl" name="sourceUrl" type="url" inputmode="url" placeholder="https://..." />
                </label>
              </div>

              <label>
                <span>Název zdroje</span>
                <input id="sourceName" name="sourceName" type="text" maxlength="80" placeholder="Jiří Petrák freetekno kalendář" />
              </label>

              <div class="field-row">
                <label>
                  <span>Tagy zdroje</span>
                  <input id="tags" name="tags" type="text" placeholder="festival, crew, místo" />
                </label>
                <label>
                  <span>URL galerie</span>
                  <input id="galleryImageUrls" name="galleryImageUrls" type="text" placeholder="https://..., https://..." />
                </label>
              </div>
            </fieldset>

            <fieldset id="gated-fields" class="form-section gated-fields" hidden>
              <legend>Tajná vrstva</legend>
              <div class="field-row">
                <label>
                  <span>Kód k odemknutí</span>
                  <input id="unlockCode" name="unlockCode" type="password" minlength="8" maxlength="128" />
                </label>
                <label>
                  <span>Název tajné lokace</span>
                  <input id="secretLocationName" name="secretLocationName" type="text" maxlength="180" />
                </label>
              </div>
              <div class="field-row">
                <label>
                  <span>Šířka</span>
                  <input id="secretLatitude" name="secretLatitude" type="number" step="0.000001" min="-90" max="90" />
                </label>
                <label>
                  <span>Délka</span>
                  <input id="secretLongitude" name="secretLongitude" type="number" step="0.000001" min="-180" max="180" />
                </label>
              </div>
              <label>
                <span>Tajné info</span>
                <textarea id="secretInfo" name="secretInfo" maxlength="4400"></textarea>
              </label>
              <label>
                <span>Poznámka k mapě</span>
                <textarea id="secretMapNote" name="secretMapNote" maxlength="500"></textarea>
              </label>
            </fieldset>

            <div class="action-row editor-actions">
              <button id="save-event" type="submit">Uložit koncept</button>
              <p id="form-status" class="status-line neutral">Připraveno.</p>
            </div>
          </form>
        </div>

      <aside class="side-column">
        <section class="panel">
          <div class="panel-head">
            <div>
              <p class="kicker">Zrcadlení</p>
              <h2>Import Jiří Petrák</h2>
            </div>
          </div>
          <div class="action-row">
            <button id="preview-import" type="button">Náhled</button>
            <button id="sync-import" type="button">Synchronizovat koncepty</button>
          </div>
          <p id="import-status" class="status-line neutral">Import vytváří veřejné koncepty.</p>
          <div id="import-preview" class="preview-list" hidden></div>
        </section>

        <section class="panel">
          <div class="panel-head">
            <div>
              <p class="kicker">Relaye</p>
              <h2>Diagnostika</h2>
            </div>
            <button id="reload-diagnostics" type="button">Zkontrolovat</button>
          </div>
          <div id="diagnostics" class="diagnostics">Nenačteno.</div>
        </section>
      </aside>
      </div>

      <section class="panel events-panel">
        <div class="panel-head">
          <div>
            <p class="kicker">Inventář</p>
            <h2>Akce</h2>
          </div>
          <div class="table-tools">
            <input id="event-filter" type="search" placeholder="Filtrovat název, slug, zdroj, město" />
            <select id="status-filter" aria-label="Stav publikace">
              <option value="all">Všechny stavy</option>
              <option value="draft">Koncepty</option>
              <option value="live">Publikované</option>
            </select>
            <select id="access-filter" aria-label="Typ přístupu">
              <option value="all">Všechny typy</option>
              <option value="public">Veřejné</option>
              <option value="gated">Na kód</option>
            </select>
            <select id="source-filter" aria-label="Typ zdroje">
              <option value="all">Všechny zdroje</option>
              <option value="imported">Importované</option>
              <option value="manual">Ručně</option>
            </select>
            <select id="time-filter" aria-label="Čas akce">
              <option value="all">Všechna data</option>
              <option value="upcoming">Nadcházející</option>
              <option value="past">Minulé</option>
              <option value="missing-image">Bez plakátu</option>
            </select>
            <button id="reload-events" type="button">Obnovit</button>
          </div>
        </div>
        <div class="bulk-bar">
          <label class="select-filtered">
            <input id="select-filtered" type="checkbox" />
            <span>Vybrat filtrované</span>
          </label>
          <strong id="inventory-count">0 zobrazeno</strong>
          <strong id="selected-count">0 vybráno</strong>
          <button id="bulk-publish" type="button" disabled>Publikovat vybrané koncepty</button>
          <button id="bulk-delete" type="button" disabled>Smazat vybrané</button>
          <button id="clear-selection" type="button" disabled>Vyčistit</button>
        </div>
        <div id="events-table" class="events-table" role="table"></div>
      </section>
    </section>
  </main>
</Layout>

<script>
  const state = {
    authenticated: false,
    events: [],
    selectedSlugs: new Set(),
    filters: {
      query: "",
      status: "all",
      access: "all",
      source: "all",
      time: "all",
    },
  };

  const dateFormatter = new Intl.DateTimeFormat("cs-CZ", { dateStyle: "medium", timeStyle: "short" });

  const accessForm = document.getElementById("access-form");
  const accessGate = document.getElementById("access-gate");
  const adminSecretInput = document.getElementById("adminSecret");
  const unlockButton = document.getElementById("unlock-button");
  const authStatus = document.getElementById("auth-status");
  const workspace = document.getElementById("workspace");
  const globalStatus = document.getElementById("global-status");
  const authState = document.getElementById("auth-state");
  const eventCount = document.getElementById("event-count");
  const relayState = document.getElementById("relay-state");
  const importState = document.getElementById("import-state");

  const eventForm = document.getElementById("event-form");
  const gatedFields = document.getElementById("gated-fields");
  const resetFormButton = document.getElementById("reset-form");
  const saveEventButton = document.getElementById("save-event");
  const publishInput = document.getElementById("isPublished");
  const formStatus = document.getElementById("form-status");
  const eventsTable = document.getElementById("events-table");
  const reloadEventsButton = document.getElementById("reload-events");
  const eventFilter = document.getElementById("event-filter");
  const statusFilter = document.getElementById("status-filter");
  const accessFilter = document.getElementById("access-filter");
  const sourceFilter = document.getElementById("source-filter");
  const timeFilter = document.getElementById("time-filter");
  const selectFiltered = document.getElementById("select-filtered");
  const inventoryCount = document.getElementById("inventory-count");
  const selectedCount = document.getElementById("selected-count");
  const bulkPublishButton = document.getElementById("bulk-publish");
  const bulkDeleteButton = document.getElementById("bulk-delete");
  const clearSelectionButton = document.getElementById("clear-selection");

  const previewImportButton = document.getElementById("preview-import");
  const syncImportButton = document.getElementById("sync-import");
  const importStatus = document.getElementById("import-status");
  const importPreview = document.getElementById("import-preview");
  const reloadDiagnosticsButton = document.getElementById("reload-diagnostics");
  const diagnostics = document.getElementById("diagnostics");

  function setStatus(target, message, tone = "neutral") {
    if (!(target instanceof HTMLElement)) return;
    target.textContent = message;
    target.className = `status-line ${tone}`;
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function setBusy(button, busy) {
    if (button instanceof HTMLButtonElement) button.disabled = busy;
  }

  function adminHeaders(json = false) {
    if (!(adminSecretInput instanceof HTMLInputElement) || !adminSecretInput.value.trim()) {
      throw new Error("Chybí admin kód.");
    }
    return {
      Authorization: `Bearer ${adminSecretInput.value.trim()}`,
      ...(json ? { "Content-Type": "application/json" } : {}),
    };
  }

  async function parseResponse(response) {
    const json = await response.json().catch(() => null);
    if (!response.ok || !json?.ok) {
      throw new Error(json?.error?.message || `Požadavek selhal se stavem ${response.status}`);
    }
    return json.data;
  }

  function toLocalInputValue(value) {
    if (!value) return "";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "";
    const offsetMs = date.getTimezoneOffset() * 60000;
    return new Date(date.getTime() - offsetMs).toISOString().slice(0, 16);
  }

  function toIsoFromLocal(value) {
    if (!value) return undefined;
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
  }

  function listFromInput(value) {
    return String(value || "")
      .split(",")
      .map((item) => item.trim())
      .filter(Boolean);
  }

  function selectedAccessType() {
    if (!(eventForm instanceof HTMLFormElement)) return "public";
    const data = new FormData(eventForm);
    return data.get("accessType") === "gated" ? "gated" : "public";
  }

  function isEditingEvent() {
    if (!(eventForm instanceof HTMLFormElement)) return false;
    const slug = eventForm.elements.namedItem("slug");
    return slug instanceof HTMLInputElement && Boolean(slug.value);
  }

  function syncSaveButtonLabel() {
    if (!(saveEventButton instanceof HTMLButtonElement)) return;
    if (isEditingEvent()) {
      saveEventButton.textContent = "Upravit akci";
      return;
    }

    saveEventButton.textContent = publishInput instanceof HTMLInputElement && publishInput.checked ? "Publikovat akci" : "Uložit koncept";
  }

  function syncAccessMode() {
    const gated = selectedAccessType() === "gated";
    if (gatedFields instanceof HTMLElement) gatedFields.hidden = !gated;
    for (const input of document.querySelectorAll("#gated-fields input, #gated-fields textarea")) {
      if (input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement) {
        input.required = gated && ["unlockCode", "secretLocationName", "secretLatitude", "secretLongitude", "secretInfo"].includes(input.name);
      }
    }
    syncSaveButtonLabel();
  }

  function resetEditor() {
    if (!(eventForm instanceof HTMLFormElement)) return;
    eventForm.reset();
    const slug = document.getElementById("slug");
    if (slug instanceof HTMLInputElement) slug.value = "";
    syncAccessMode();
    syncSaveButtonLabel();
    setStatus(formStatus, "Připraveno.", "neutral");
  }

  function fillEditor(item) {
    if (!(eventForm instanceof HTMLFormElement)) return;
    resetEditor();
    const fields = {
      slug: item.slug,
      title: item.title,
      startsAt: toLocalInputValue(item.startsAt),
      endAt: toLocalInputValue(item.endAt),
      publicLocation: item.publicLocation,
      publicLatitude: item.publicLatitude ?? "",
      publicLongitude: item.publicLongitude ?? "",
      summary: item.summary,
      genres: (item.genres || []).join(", "),
      lineup: (item.lineup || []).join(", "),
      tags: (item.tags || []).join(", "),
      galleryImageUrls: (item.galleryImageUrls || []).join(", "),
      coverImageUrl: item.coverImageUrl || "",
      externalUrl: item.externalUrl || "",
      sourceUrl: item.source?.url || "",
      sourceName: item.source?.name || "",
    };
    for (const [name, value] of Object.entries(fields)) {
      const field = eventForm.elements.namedItem(name);
      if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) field.value = value;
    }
    const published = eventForm.elements.namedItem("isPublished");
    if (published instanceof HTMLInputElement) published.checked = Boolean(item.isPublished);
    const access = eventForm.querySelector(`input[name="accessType"][value="${item.accessType || "public"}"]`);
    if (access instanceof HTMLInputElement) access.checked = true;
    syncAccessMode();
    syncSaveButtonLabel();
    setStatus(formStatus, `Upravuješ ${item.slug}. Uložení nahradí nejnovější Nostr událost pro tento slug.`, "warning");
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function filteredEvents() {
    const query = state.filters.query.trim().toLowerCase();
    const now = Date.now();
    return state.events.filter((item) => {
      const searchable = [
        item.title,
        item.slug,
        item.publicLocation,
        item.source?.name,
        item.source?.url,
        item.externalUrl,
        ...(item.tags || []),
        ...(item.genres || []),
        ...(item.lineup || []),
      ]
        .filter(Boolean)
        .join(" ")
        .toLowerCase();

      const itemEnd = new Date(item.endAt || item.startsAt).getTime();
      const matchesQuery = !query || searchable.includes(query);
      const matchesStatus =
        state.filters.status === "all" ||
        (state.filters.status === "draft" && !item.isPublished) ||
        (state.filters.status === "live" && item.isPublished);
      const matchesAccess = state.filters.access === "all" || item.accessType === state.filters.access;
      const matchesSource =
        state.filters.source === "all" ||
        (state.filters.source === "imported" && item.source) ||
        (state.filters.source === "manual" && !item.source);
      const matchesTime =
        state.filters.time === "all" ||
        (state.filters.time === "upcoming" && itemEnd >= now) ||
        (state.filters.time === "past" && itemEnd < now) ||
        (state.filters.time === "missing-image" && !item.coverImageUrl);

      return matchesQuery && matchesStatus && matchesAccess && matchesSource && matchesTime;
    });
  }

  function badge(text, tone = "") {
    return `<span class="badge ${tone}">${text}</span>`;
  }

  function eventDateRange(item) {
    const start = dateFormatter.format(new Date(item.startsAt));
    return item.endAt ? `${start} -> ${dateFormatter.format(new Date(item.endAt))}` : start;
  }

  function compactList(values, max = 4) {
    const list = (values || []).filter(Boolean);
    if (list.length <= max) return list.join(", ");
    return `${list.slice(0, max).join(", ")} +${list.length - max}`;
  }

  function syncBulkControls(rows) {
    const selectedRows = state.events.filter((item) => state.selectedSlugs.has(item.slug));
    const selectedDrafts = selectedRows.filter((item) => !item.isPublished);
    const allFilteredSelected = rows.length > 0 && rows.every((item) => state.selectedSlugs.has(item.slug));

    if (inventoryCount instanceof HTMLElement) inventoryCount.textContent = `${rows.length} zobrazeno / ${state.events.length} celkem`;
    if (selectedCount instanceof HTMLElement) selectedCount.textContent = `${selectedRows.length} vybráno`;
    if (bulkPublishButton instanceof HTMLButtonElement) bulkPublishButton.disabled = selectedDrafts.length === 0;
    if (bulkDeleteButton instanceof HTMLButtonElement) bulkDeleteButton.disabled = selectedRows.length === 0;
    if (clearSelectionButton instanceof HTMLButtonElement) clearSelectionButton.disabled = selectedRows.length === 0;
    if (selectFiltered instanceof HTMLInputElement) {
      selectFiltered.checked = allFilteredSelected;
      selectFiltered.indeterminate = !allFilteredSelected && rows.some((item) => state.selectedSlugs.has(item.slug));
    }
  }

  function renderEvents() {
    if (!(eventsTable instanceof HTMLElement)) return;
    const rows = filteredEvents();
    if (eventCount instanceof HTMLElement) eventCount.textContent = String(state.events.length);
    syncBulkControls(rows);
    if (rows.length === 0) {
      eventsTable.innerHTML = `<p class="empty-state">Nic neodpovídá filtru.</p>`;
      return;
    }

    const header = `
      <div class="event-table-head" role="row">
        <span></span>
        <span>Plakát</span>
        <span>Ovládání</span>
        <span>Datum</span>
        <span>Lokalita</span>
        <span>Zdroj</span>
        <span>Stav</span>
        <span>Akce</span>
      </div>
    `;

    eventsTable.innerHTML =
      header +
      rows
        .map((item, index) => {
        const sourceBadge = item.source ? badge("import", "soft") : "";
        const liveBadge = item.isPublished ? badge("publikováno", "live") : badge("koncept", "draft");
        const accessBadge = item.accessType === "gated" ? badge("na kód", "danger") : badge("veřejná", "soft");
        const sourceLine = item.source?.url ? `<a href="${escapeHtml(item.source.url)}" target="_blank" rel="noreferrer">zdroj</a>` : "ručně";
        const thumb = item.coverImageUrl
          ? `<img class="event-thumb" src="${escapeHtml(item.coverImageUrl)}" alt="" loading="lazy" decoding="async" referrerpolicy="no-referrer" />`
          : `<span class="event-thumb-empty" aria-hidden="true"></span>`;
        const tags = compactList([...(item.tags || []), ...(item.genres || [])]);
        const selected = state.selectedSlugs.has(item.slug);
        return `
          <article class="event-row ${selected ? "selected" : ""}" data-index="${index}">
            <label class="row-select" aria-label="Vybrat ${escapeHtml(item.title)}">
              <input type="checkbox" data-action="select" data-slug="${escapeHtml(item.slug)}" ${selected ? "checked" : ""} />
            </label>
            ${thumb}
            <div class="event-main">
              <strong>${escapeHtml(item.title)}</strong>
              <span class="slug">${escapeHtml(item.slug)}</span>
              <p>${escapeHtml(String(item.summary || "").slice(0, 260))}</p>
            </div>
            <div class="event-when">${escapeHtml(eventDateRange(item))}</div>
            <div class="event-place">${escapeHtml(item.publicLocation || "Neznámá")}</div>
            <div class="event-source">
              <span>${sourceLine}</span>
              ${tags ? `<small>${escapeHtml(tags)}</small>` : ""}
            </div>
            <div class="badges">${liveBadge}${accessBadge}${sourceBadge}</div>
            <div class="row-actions">
              <button type="button" data-action="edit" data-slug="${escapeHtml(item.slug)}">Upravit</button>
              ${!item.isPublished ? `<button type="button" data-action="publish" data-slug="${escapeHtml(item.slug)}">Publikovat</button>` : `<a href="/akce/${escapeHtml(item.slug)}" target="_blank" rel="noreferrer">Otevřít</a>`}
              <button type="button" data-action="delete" data-slug="${escapeHtml(item.slug)}">Smazat</button>
            </div>
          </article>
        `;
        })
        .join("");
  }

  async function loadEvents() {
    const response = await fetch("/api/admin/events", { headers: adminHeaders() });
    const data = await parseResponse(response);
    state.events = Array.isArray(data.events) ? data.events : [];
    const knownSlugs = new Set(state.events.map((item) => item.slug));
    for (const slug of [...state.selectedSlugs]) {
      if (!knownSlugs.has(slug)) state.selectedSlugs.delete(slug);
    }
    renderEvents();
  }

  async function loadDiagnostics() {
    if (!(diagnostics instanceof HTMLElement)) return;
    const response = await fetch("/api/admin/diagnostics", { headers: adminHeaders() });
    const data = await parseResponse(response);
    const okCount = data.checks?.relays?.filter((relay) => relay.ok).length || 0;
    if (relayState instanceof HTMLElement) relayState.textContent = `${okCount}/${data.relays?.length || 0} ok`;
    diagnostics.innerHTML = `
      <p><strong>Publikuje</strong><br>${escapeHtml(data.publisherPubkey)}</p>
      <p><strong>Quorum zápisu</strong><br>${escapeHtml(data.writeMinSuccess)}</p>
      ${(data.checks?.relays || [])
        .map(
          (relay) =>
            `<p>${relay.ok ? "OK" : "CHYBA"} ${escapeHtml(relay.relay)}<br><small>${escapeHtml(
              relay.message || `${relay.events} akcí`,
            )}</small></p>`,
        )
        .join("")}
    `;
  }

  async function authenticate() {
    setBusy(unlockButton, true);
    setStatus(authStatus, "Ověřuji kód...", "warning");
    try {
      await loadEvents();
      state.authenticated = true;
      if (accessGate instanceof HTMLElement) accessGate.hidden = true;
      if (workspace instanceof HTMLElement) workspace.hidden = false;
      if (authState instanceof HTMLElement) authState.textContent = "Odemčeno";
      setStatus(globalStatus, "Pracovní plocha načtena.", "positive");
      loadDiagnostics().catch((error) => {
        if (relayState instanceof HTMLElement) relayState.textContent = "Kontrola selhala";
        setStatus(globalStatus, error instanceof Error ? error.message : "Diagnostika relayů selhala.", "warning");
      });
    } catch (error) {
      setStatus(authStatus, error instanceof Error ? error.message : "Ověření selhalo.", "danger");
    } finally {
      setBusy(unlockButton, false);
    }
  }

  async function saveEvent(event) {
    event.preventDefault();
    if (!(eventForm instanceof HTMLFormElement)) return;
    const data = new FormData(eventForm);
    const accessType = selectedAccessType();
    const payload = {
      slug: String(data.get("slug") || "").trim() || undefined,
      title: String(data.get("title") || ""),
      startsAt: toIsoFromLocal(String(data.get("startsAt") || "")),
      endAt: toIsoFromLocal(String(data.get("endAt") || "")),
      publicLocation: String(data.get("publicLocation") || ""),
      publicLatitude: data.get("publicLatitude") ? Number(data.get("publicLatitude")) : undefined,
      publicLongitude: data.get("publicLongitude") ? Number(data.get("publicLongitude")) : undefined,
      summary: String(data.get("summary") || ""),
      coverImageUrl: String(data.get("coverImageUrl") || "").trim() || undefined,
      externalUrl: String(data.get("externalUrl") || "").trim() || undefined,
      sourceUrl: String(data.get("sourceUrl") || "").trim() || undefined,
      sourceName: String(data.get("sourceName") || "").trim() || undefined,
      genres: listFromInput(data.get("genres")),
      lineup: listFromInput(data.get("lineup")),
      tags: listFromInput(data.get("tags")),
      galleryImageUrls: listFromInput(data.get("galleryImageUrls")),
      accessType,
      isPublished: data.get("isPublished") === "on",
      unlockCode: accessType === "gated" ? String(data.get("unlockCode") || "") : undefined,
      secretLocationName: accessType === "gated" ? String(data.get("secretLocationName") || "") : undefined,
      secretLatitude: accessType === "gated" ? Number(data.get("secretLatitude")) : undefined,
      secretLongitude: accessType === "gated" ? Number(data.get("secretLongitude")) : undefined,
      secretInfo: accessType === "gated" ? String(data.get("secretInfo") || "") : undefined,
      secretMapNote: accessType === "gated" ? String(data.get("secretMapNote") || "").trim() || undefined : undefined,
    };

    setStatus(formStatus, "Ukládám akci na Nostr relaye...", "warning");
    try {
      const response = await fetch("/api/admin/events", {
        method: "POST",
        headers: adminHeaders(true),
        body: JSON.stringify(payload),
      });
      const saved = await parseResponse(response);
      setStatus(formStatus, `Uloženo ${saved.slug}.`, "positive");
      resetEditor();
      await loadEvents();
    } catch (error) {
      setStatus(formStatus, error instanceof Error ? error.message : "Uložení selhalo.", "danger");
    }
  }

  async function previewImport() {
    setBusy(previewImportButton, true);
    setStatus(importStatus, "Načítám náhled zdroje...", "warning");
    try {
      const response = await fetch("/api/admin/imports/jiripetrak/preview", { headers: adminHeaders() });
      const data = await parseResponse(response);
      if (importState instanceof HTMLElement) importState.textContent = `${data.events.length} nalezeno`;
      if (importPreview instanceof HTMLElement) {
        importPreview.hidden = false;
        importPreview.innerHTML = data.events
          .slice(0, 12)
          .map(
            (item) => `
              <article class="preview-item">
                <strong>${escapeHtml(item.title)}</strong>
                <span>${escapeHtml(eventDateRange(item))}</span>
                <small>${escapeHtml(item.publicLocation || "Neznámá lokalita")}</small>
                <p>${escapeHtml(String(item.summary || "").slice(0, 420))}</p>
                <small>${escapeHtml([...(item.tags || []), ...(item.genres || [])].join(", "))}</small>
                <small>${escapeHtml(item.sourceUrl)}</small>
              </article>
            `,
          )
          .join("");
      }
      setStatus(importStatus, `Náhled načetl ${data.events.length} akcí.`, "positive");
    } catch (error) {
      setStatus(importStatus, error instanceof Error ? error.message : "Náhled importu selhal.", "danger");
    } finally {
      setBusy(previewImportButton, false);
    }
  }

  async function syncImport() {
    setBusy(syncImportButton, true);
    setStatus(importStatus, "Synchronizuji importované koncepty...", "warning");
    try {
      const response = await fetch("/api/admin/imports/jiripetrak/sync", {
        method: "POST",
        headers: adminHeaders(),
      });
      const data = await parseResponse(response);
      if (importState instanceof HTMLElement) importState.textContent = `${data.created} nových / ${data.updated} upraveno`;
      setStatus(importStatus, `Synchronizováno ${data.imported} akcí ze zdroje.`, "positive");
      await loadEvents();
    } catch (error) {
      setStatus(importStatus, error instanceof Error ? error.message : "Synchronizace importu selhala.", "danger");
    } finally {
      setBusy(syncImportButton, false);
    }
  }

  async function publishSlug(slug) {
    const response = await fetch("/api/admin/events", {
      method: "PATCH",
      headers: adminHeaders(true),
      body: JSON.stringify({ slug, action: "publish" }),
    });
    await parseResponse(response);
  }

  async function deleteSlug(slug) {
    const response = await fetch("/api/admin/events", {
      method: "DELETE",
      headers: adminHeaders(true),
      body: JSON.stringify({ slug, confirmSlug: slug }),
    });
    await parseResponse(response);
  }

  async function bulkPublishSelected() {
    const selectedDrafts = state.events.filter((item) => state.selectedSlugs.has(item.slug) && !item.isPublished);
    if (selectedDrafts.length === 0) return;

    setStatus(globalStatus, `Publikuji ${selectedDrafts.length} konceptů...`, "warning");
    setBusy(bulkPublishButton, true);
    try {
      for (const item of selectedDrafts) {
        await publishSlug(item.slug);
      }
      setStatus(globalStatus, `Publikováno ${selectedDrafts.length} konceptů.`, "positive");
      await loadEvents();
    } catch (error) {
      setStatus(globalStatus, error instanceof Error ? error.message : "Hromadné publikování selhalo.", "danger");
    } finally {
      setBusy(bulkPublishButton, false);
      renderEvents();
    }
  }

  async function bulkDeleteSelected() {
    const selectedRows = state.events.filter((item) => state.selectedSlugs.has(item.slug));
    if (selectedRows.length === 0) return;

    const confirmation = window.prompt(`Napiš SMAZAT ${selectedRows.length} pro smazání ${selectedRows.length} vybraných akcí.`);
    if (confirmation !== `SMAZAT ${selectedRows.length}`) return;

    setStatus(globalStatus, `Mažu ${selectedRows.length} akcí...`, "warning");
    setBusy(bulkDeleteButton, true);
    try {
      for (const item of selectedRows) {
        await deleteSlug(item.slug);
        state.selectedSlugs.delete(item.slug);
      }
      setStatus(globalStatus, `Smazáno ${selectedRows.length} akcí.`, "positive");
      await loadEvents();
    } catch (error) {
      setStatus(globalStatus, error instanceof Error ? error.message : "Hromadné mazání selhalo.", "danger");
    } finally {
      setBusy(bulkDeleteButton, false);
      renderEvents();
    }
  }

  async function handleEventAction(event) {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const action = target.dataset.action;
    const slug = target.dataset.slug;
    if (!action || !slug) return;
    const item = state.events.find((candidate) => candidate.slug === slug);
    if (!item) return;

    if (action === "select") {
      if (target instanceof HTMLInputElement && target.checked) {
        state.selectedSlugs.add(slug);
      } else {
        state.selectedSlugs.delete(slug);
      }
      renderEvents();
      return;
    }

    if (action === "edit") {
      fillEditor(item);
      return;
    }

    try {
      if (action === "publish") {
        await publishSlug(slug);
        setStatus(globalStatus, `Publikováno ${slug}.`, "positive");
      }

      if (action === "delete") {
        const confirmSlug = window.prompt(`Napiš slug pro smazání: ${slug}`);
        if (confirmSlug !== slug) return;
        await deleteSlug(slug);
        state.selectedSlugs.delete(slug);
        setStatus(globalStatus, `Smazáno ${slug}.`, "positive");
      }

      await loadEvents();
    } catch (error) {
      setStatus(globalStatus, error instanceof Error ? error.message : `Akce ${action} selhala.`, "danger");
    }
  }

  for (const input of document.querySelectorAll('input[name="accessType"]')) {
    input.addEventListener("change", syncAccessMode);
  }
  syncAccessMode();
  publishInput?.addEventListener("change", syncSaveButtonLabel);

  accessForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    authenticate();
  });
  eventForm?.addEventListener("submit", saveEvent);
  resetFormButton?.addEventListener("click", resetEditor);
  reloadEventsButton?.addEventListener("click", async () => {
    await loadEvents();
  });
  reloadDiagnosticsButton?.addEventListener("click", async () => {
    await loadDiagnostics();
  });
  previewImportButton?.addEventListener("click", previewImport);
  syncImportButton?.addEventListener("click", syncImport);
  eventsTable?.addEventListener("click", handleEventAction);
  eventFilter?.addEventListener("input", () => {
    state.filters.query = eventFilter instanceof HTMLInputElement ? eventFilter.value : "";
    renderEvents();
  });
  statusFilter?.addEventListener("change", () => {
    state.filters.status = statusFilter instanceof HTMLSelectElement ? statusFilter.value : "all";
    renderEvents();
  });
  accessFilter?.addEventListener("change", () => {
    state.filters.access = accessFilter instanceof HTMLSelectElement ? accessFilter.value : "all";
    renderEvents();
  });
  sourceFilter?.addEventListener("change", () => {
    state.filters.source = sourceFilter instanceof HTMLSelectElement ? sourceFilter.value : "all";
    renderEvents();
  });
  timeFilter?.addEventListener("change", () => {
    state.filters.time = timeFilter instanceof HTMLSelectElement ? timeFilter.value : "all";
    renderEvents();
  });
  selectFiltered?.addEventListener("change", () => {
    const rows = filteredEvents();
    const checked = selectFiltered instanceof HTMLInputElement && selectFiltered.checked;
    for (const item of rows) {
      if (checked) {
        state.selectedSlugs.add(item.slug);
      } else {
        state.selectedSlugs.delete(item.slug);
      }
    }
    renderEvents();
  });
  clearSelectionButton?.addEventListener("click", () => {
    state.selectedSlugs.clear();
    renderEvents();
  });
  bulkPublishButton?.addEventListener("click", bulkPublishSelected);
  bulkDeleteButton?.addEventListener("click", bulkDeleteSelected);
</script>

