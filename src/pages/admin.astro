---
export const prerender = false;

import Layout from "../layouts/Layout.astro";

const cspNonce = Astro.locals.cspNonce;
---

<Layout bodyClass="admin-body">
  <main class="admin-shell">
    <section id="access-gate" class="access-gate">
      <div class="gate-card">
        <p class="kicker">Admin přístup</p>
        <h1>RaveMap řízení</h1>
        <p class="gate-copy">Nostr operace zůstanou skryté, dokud neověříš admin kód.</p>

        <form id="access-form" class="access-form">
          <input id="adminSecret" name="adminSecret" type="password" minlength="24" placeholder="Admin kód" autocomplete="current-password" required />
          <button id="unlock-button" type="submit">Odemknout</button>
        </form>

        <p id="auth-status" class="status-line neutral">Zadej admin kód pro otevření kokpitu.</p>
      </div>
    </section>

    <section id="workspace" class="workspace" hidden>
      <header class="admin-topbar">
        <div>
          <p class="kicker">Nostr kokpit</p>
          <h1>RaveMap Admin</h1>
        </div>
        <div class="topbar-actions">
          <p class="topbar-note">Podepsané publikování na relaye. Veřejné a kódem zamčené akce.</p>
          <button id="clear-admin-secret" type="button">Odhlásit</button>
        </div>
      </header>

      <section class="status-grid">
        <div class="metric">
          <span>Přístup</span>
          <strong id="auth-state">Zamčeno</strong>
        </div>
        <div class="metric">
          <span>Akce</span>
          <strong id="event-count">0</strong>
        </div>
        <div class="metric">
          <span>Relaye</span>
          <strong id="relay-state">Nezkontrolováno</strong>
        </div>
        <div class="metric">
          <span>Import</span>
          <strong id="import-state">Čeká</strong>
        </div>
      </section>

      <p id="global-status" class="status-line neutral">Pracovní plocha načtena.</p>

      <section class="panel review-panel" aria-labelledby="review-title">
        <div class="panel-head">
          <div>
            <p class="kicker">Review</p>
            <h2 id="review-title">Co potřebuje pozornost</h2>
          </div>
          <button id="clear-review-filters" type="button">Vyčistit filtry</button>
        </div>
        <div id="review-summary" class="review-summary" aria-label="Souhrn inventáře"></div>
        <div id="review-queues" class="review-queues" aria-label="Review fronty"></div>
      </section>

      <div class="cockpit-grid">
        <div class="panel form-panel">
          <div class="panel-head">
            <div>
              <p class="kicker">Úpravy</p>
              <h2>Vytvořit nebo upravit akci</h2>
            </div>
            <button id="reset-form" type="button">Nová</button>
          </div>

          <form id="event-form" class="event-form">
            <input id="slug" name="slug" type="hidden" />

            <div class="editor-mode-row">
              <div class="segmented" role="group" aria-label="Typ přístupu k akci">
                <label>
                  <input type="radio" name="accessType" value="public" checked />
                  <span>Veřejná</span>
                </label>
                <label>
                  <input type="radio" name="accessType" value="gated" />
                  <span>Na kód</span>
                </label>
              </div>

              <label class="publish-check">
                <input id="isPublished" name="isPublished" type="checkbox" />
                <span>Publikovat</span>
              </label>
            </div>

            <fieldset class="form-section">
              <legend>Základ</legend>
              <label class="title-field">
                <span>Název</span>
                <input id="title" name="title" type="text" minlength="3" maxlength="180" required />
              </label>

              <div class="field-row">
                <label>
                  <span>Začátek</span>
                  <input id="startsAt" name="startsAt" type="datetime-local" required />
                </label>
                <label>
                  <span>Konec</span>
                  <input id="endAt" name="endAt" type="datetime-local" />
                </label>
              </div>

              <label>
                <span>Veřejná lokalita</span>
                <input id="publicLocation" name="publicLocation" type="text" minlength="2" maxlength="180" required />
              </label>
              <div class="field-row">
                <label>
                  <span>Veřejná šířka</span>
                  <input id="publicLatitude" name="publicLatitude" type="number" step="0.000001" min="-90" max="90" />
                </label>
                <label>
                  <span>Veřejná délka</span>
                  <input id="publicLongitude" name="publicLongitude" type="number" step="0.000001" min="-180" max="180" />
                </label>
              </div>
            </fieldset>

            <fieldset class="form-section">
              <legend>Veřejný obsah</legend>
              <label>
                <span>Popis</span>
                <textarea id="summary" name="summary" minlength="10" maxlength="2000" required></textarea>
              </label>

              <div class="field-row">
                <label>
                  <span>Žánry</span>
                  <input id="genres" name="genres" type="text" placeholder="tekno, freetekno" />
                </label>
                <label>
                  <span>Lineup</span>
                  <input id="lineup" name="lineup" type="text" placeholder="umělec, crew" />
                </label>
              </div>

              <label>
                <span>URL plakátu</span>
                <input id="coverImageUrl" name="coverImageUrl" type="url" inputmode="url" placeholder="https://..." />
              </label>
            </fieldset>

            <fieldset class="form-section">
              <legend>Zdroj</legend>
              <div class="field-row">
                <label>
                  <span>Externí URL</span>
                  <input id="externalUrl" name="externalUrl" type="url" inputmode="url" placeholder="https://..." />
                </label>
                <label>
                  <span>SimpleX kontakt</span>
                  <input id="simplexUrl" name="simplexUrl" type="text" inputmode="url" placeholder="https://smp12.simplex.im/..." />
                </label>
              </div>

              <div class="field-row">
                <label>
                  <span>URL zdroje</span>
                  <input id="sourceUrl" name="sourceUrl" type="url" inputmode="url" placeholder="https://..." />
                </label>
              </div>

              <label>
                <span>Název zdroje</span>
                <input id="sourceName" name="sourceName" type="text" maxlength="80" placeholder="Jiří Petrák freetekno kalendář" />
              </label>

              <div class="field-row">
                <label>
                  <span>Tagy zdroje</span>
                  <input id="tags" name="tags" type="text" placeholder="festival, crew, místo" />
                </label>
                <label>
                  <span>URL galerie</span>
                  <input id="galleryImageUrls" name="galleryImageUrls" type="text" placeholder="https://..., https://..." />
                </label>
              </div>
            </fieldset>

            <fieldset id="gated-fields" class="form-section gated-fields" hidden>
              <legend>Tajná vrstva</legend>
              <div class="field-row">
                <label>
                  <span>Kód k odemknutí</span>
                  <input id="unlockCode" name="unlockCode" type="password" minlength="8" maxlength="128" autocomplete="new-password" />
                </label>
                <label>
                  <span>Název tajné lokace</span>
                  <input id="secretLocationName" name="secretLocationName" type="text" maxlength="180" />
                </label>
              </div>
              <div class="field-row">
                <label>
                  <span>Šířka</span>
                  <input id="secretLatitude" name="secretLatitude" type="number" step="0.000001" min="-90" max="90" />
                </label>
                <label>
                  <span>Délka</span>
                  <input id="secretLongitude" name="secretLongitude" type="number" step="0.000001" min="-180" max="180" />
                </label>
              </div>
              <label>
                <span>Tajné info</span>
                <textarea id="secretInfo" name="secretInfo" maxlength="4400"></textarea>
              </label>
              <label>
                <span>Poznámka k mapě</span>
                <textarea id="secretMapNote" name="secretMapNote" maxlength="500"></textarea>
              </label>
            </fieldset>

            <div class="action-row editor-actions">
              <button id="save-event" type="submit">Uložit koncept</button>
              <p id="editor-readiness" class="status-line neutral">Editor čeká na akci.</p>
              <p id="form-status" class="status-line neutral">Připraveno.</p>
            </div>
          </form>
        </div>

      <aside class="side-column">
        <section class="panel">
          <div class="panel-head">
            <div>
              <p class="kicker">Zrcadlení</p>
              <h2>Import Jiří Petrák</h2>
            </div>
          </div>
          <div class="action-row">
            <button id="preview-import" type="button">Náhled</button>
            <button id="sync-import" type="button">Synchronizovat koncepty</button>
          </div>
          <p id="import-status" class="status-line neutral">Import vytváří veřejné koncepty.</p>
          <div id="import-preview" class="preview-list" hidden></div>
        </section>

        <section class="panel">
          <div class="panel-head">
            <div>
              <p class="kicker">Crew účty</p>
              <h2>Profily a přiřazení</h2>
            </div>
            <button id="reload-crews" type="button">Obnovit</button>
          </div>
          <form id="crew-form" class="event-form">
            <div class="field-row">
              <label>
                <span>Slug</span>
                <input id="crewSlug" name="slug" type="text" minlength="3" maxlength="120" pattern="[a-z0-9-]+" required />
              </label>
              <label>
                <span>Crew kód</span>
                <input id="crewCode" name="crewCode" type="password" minlength="12" maxlength="160" autocomplete="new-password" />
              </label>
            </div>
            <div class="code-tools">
              <button id="generate-crew-code" type="button">Generovat kód</button>
              <button id="copy-crew-code" type="button">Kopírovat kód</button>
              <button id="copy-crew-invite" type="button">Kopírovat pozvánku</button>
            </div>
            <div class="handoff-panel">
              <strong>Handoff pro crew</strong>
              <p>Po vygenerování kódu zkopíruj pozvánku. Obsahuje Studio URL, veřejný crew profil, slug a jednorázový crew kód.</p>
            </div>
            <label>
              <span>Název</span>
              <input id="crewName" name="name" type="text" maxlength="80" />
            </label>
            <label>
              <span>Popis</span>
              <textarea id="crewSummary" name="summary" maxlength="1000"></textarea>
            </label>
            <div class="field-row">
              <label>
                <span>Avatar URL</span>
                <input id="crewAvatarUrl" name="avatarUrl" type="url" />
              </label>
              <label>
                <span>Banner URL</span>
                <input id="crewBannerUrl" name="bannerUrl" type="url" />
              </label>
            </div>
            <div class="field-row">
              <label>
                <span>SimpleX</span>
                <input id="crewSimplexUrl" name="simplexUrl" type="text" />
              </label>
              <label>
                <span>Lightning adresa</span>
                <input id="crewLightningAddress" name="lightningAddress" type="text" placeholder="crew@domena.cz" />
              </label>
            </div>
            <label>
              <span>Web</span>
              <input id="crewWebsiteUrl" name="websiteUrl" type="url" />
            </label>
            <div class="action-row">
              <button id="save-crew" type="submit">Uložit crew</button>
              <button id="rotate-crew-code" type="button">Rotovat kód</button>
              <button id="archive-crew" type="button">Archivovat</button>
            </div>
          </form>
          <form id="assign-crew-form" class="event-form">
            <div class="field-row">
              <label>
                <span>Slug akce</span>
                <input id="assignEventSlug" name="eventSlug" type="text" minlength="3" maxlength="120" pattern="[a-z0-9-]+" />
              </label>
              <label>
                <span>Crew slug</span>
                <input id="assignCrewSlug" name="crewSlug" type="text" minlength="3" maxlength="120" pattern="[a-z0-9-]+" />
              </label>
            </div>
            <button id="assign-crew" type="submit">Přiřadit akci crew</button>
          </form>
          <p id="crew-status" class="status-line neutral">Crew správa připravena.</p>
          <div id="crew-list" class="preview-list"></div>
        </section>

        <section class="panel">
          <div class="panel-head">
            <div>
              <p class="kicker">Relaye</p>
              <h2>Diagnostika</h2>
            </div>
            <button id="reload-diagnostics" type="button">Zkontrolovat</button>
          </div>
          <div id="diagnostics" class="diagnostics">Nenačteno.</div>
        </section>
      </aside>
      </div>

      <section class="panel events-panel">
        <div class="panel-head">
          <div>
            <p class="kicker">Inventář</p>
            <h2>Akce</h2>
          </div>
          <div class="table-tools">
            <input id="event-filter" type="search" placeholder="Filtrovat název, slug, zdroj, město" />
            <select id="status-filter" aria-label="Stav publikace">
              <option value="all">Všechny stavy</option>
              <option value="draft">Koncepty</option>
              <option value="live">Publikované</option>
            </select>
            <select id="access-filter" aria-label="Typ přístupu">
              <option value="all">Všechny typy</option>
              <option value="public">Veřejné</option>
              <option value="gated">Na kód</option>
            </select>
            <select id="source-filter" aria-label="Typ zdroje">
              <option value="all">Všechny původy</option>
              <option value="community">Komunitní</option>
              <option value="crew">Crew</option>
              <option value="imported">Importované</option>
              <option value="admin">Admin</option>
              <option value="manual">Ručně bez zdroje</option>
            </select>
            <select id="time-filter" aria-label="Čas akce">
              <option value="all">Všechna data</option>
              <option value="upcoming">Nadcházející</option>
              <option value="past">Minulé</option>
              <option value="missing-image">Bez plakátu</option>
            </select>
            <button id="reload-events" type="button">Obnovit</button>
          </div>
        </div>
        <div id="quick-filters" class="quick-filters" aria-label="Rychlé filtry inventáře"></div>
        <div id="active-filters" class="active-filters" aria-live="polite"></div>
        <div class="bulk-bar">
          <label class="select-filtered">
            <input id="select-filtered" type="checkbox" />
            <span>Vybrat filtrované</span>
          </label>
          <strong id="inventory-count">0 zobrazeno</strong>
          <strong id="selected-count">0 vybráno</strong>
          <button id="bulk-publish" type="button" disabled>Publikovat vybrané koncepty</button>
          <button id="bulk-delete" type="button" disabled>Smazat vybrané</button>
          <button id="clear-selection" type="button" disabled>Vyčistit</button>
        </div>
        <div id="events-table" class="events-table" role="table"></div>
      </section>
    </section>
  </main>
</Layout>

<script nonce={cspNonce}>
  const state = {
    authenticated: false,
    events: [],
    crews: [],
    selectedSlugs: new Set(),
    filters: {
      query: "",
      status: "all",
      access: "all",
      source: "all",
      time: "all",
      review: "all",
    },
  };

  const dateFormatter = new Intl.DateTimeFormat("cs-CZ", { dateStyle: "medium", timeStyle: "short" });

  const accessForm = document.getElementById("access-form");
  const accessGate = document.getElementById("access-gate");
  const adminSecretInput = document.getElementById("adminSecret");
  const unlockButton = document.getElementById("unlock-button");
  const clearAdminSecretButton = document.getElementById("clear-admin-secret");
  const authStatus = document.getElementById("auth-status");
  const workspace = document.getElementById("workspace");
  const globalStatus = document.getElementById("global-status");
  const authState = document.getElementById("auth-state");
  const eventCount = document.getElementById("event-count");
  const relayState = document.getElementById("relay-state");
  const importState = document.getElementById("import-state");
  const reviewSummary = document.getElementById("review-summary");
  const reviewQueues = document.getElementById("review-queues");
  const clearReviewFiltersButton = document.getElementById("clear-review-filters");

  const eventForm = document.getElementById("event-form");
  const gatedFields = document.getElementById("gated-fields");
  const resetFormButton = document.getElementById("reset-form");
  const saveEventButton = document.getElementById("save-event");
  const publishInput = document.getElementById("isPublished");
  const editorReadiness = document.getElementById("editor-readiness");
  const formStatus = document.getElementById("form-status");
  const eventsTable = document.getElementById("events-table");
  const reloadEventsButton = document.getElementById("reload-events");
  const eventFilter = document.getElementById("event-filter");
  const statusFilter = document.getElementById("status-filter");
  const accessFilter = document.getElementById("access-filter");
  const sourceFilter = document.getElementById("source-filter");
  const timeFilter = document.getElementById("time-filter");
  const selectFiltered = document.getElementById("select-filtered");
  const inventoryCount = document.getElementById("inventory-count");
  const selectedCount = document.getElementById("selected-count");
  const bulkPublishButton = document.getElementById("bulk-publish");
  const bulkDeleteButton = document.getElementById("bulk-delete");
  const clearSelectionButton = document.getElementById("clear-selection");
  const quickFilters = document.getElementById("quick-filters");
  const activeFilters = document.getElementById("active-filters");

  const previewImportButton = document.getElementById("preview-import");
  const syncImportButton = document.getElementById("sync-import");
  const importStatus = document.getElementById("import-status");
  const importPreview = document.getElementById("import-preview");
  const reloadDiagnosticsButton = document.getElementById("reload-diagnostics");
  const diagnostics = document.getElementById("diagnostics");
  const crewForm = document.getElementById("crew-form");
  const assignCrewForm = document.getElementById("assign-crew-form");
  const reloadCrewsButton = document.getElementById("reload-crews");
  const rotateCrewCodeButton = document.getElementById("rotate-crew-code");
  const archiveCrewButton = document.getElementById("archive-crew");
  const generateCrewCodeButton = document.getElementById("generate-crew-code");
  const copyCrewCodeButton = document.getElementById("copy-crew-code");
  const copyCrewInviteButton = document.getElementById("copy-crew-invite");
  const crewStatus = document.getElementById("crew-status");
  const crewList = document.getElementById("crew-list");

  function setStatus(target, message, tone = "neutral") {
    if (!(target instanceof HTMLElement)) return;
    target.textContent = message;
    target.className = `status-line ${tone}`;
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function setBusy(button, busy) {
    if (button instanceof HTMLButtonElement) button.disabled = busy;
  }

  function adminHeaders(json = false) {
    if (!(adminSecretInput instanceof HTMLInputElement) || !adminSecretInput.value.trim()) {
      throw new Error("Chybí admin kód.");
    }
    return {
      Authorization: `Bearer ${adminSecretInput.value.trim()}`,
      ...(json ? { "Content-Type": "application/json" } : {}),
    };
  }

  async function parseResponse(response) {
    const json = await response.json().catch(() => null);
    if (!response.ok || !json?.ok) {
      throw new Error(json?.error?.message || `Požadavek selhal se stavem ${response.status}`);
    }
    return json.data;
  }

  function toLocalInputValue(value) {
    if (!value) return "";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "";
    const offsetMs = date.getTimezoneOffset() * 60000;
    return new Date(date.getTime() - offsetMs).toISOString().slice(0, 16);
  }

  function toIsoFromLocal(value) {
    if (!value) return undefined;
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
  }

  function listFromInput(value) {
    return String(value || "")
      .split(",")
      .map((item) => item.trim())
      .filter(Boolean);
  }

  function selectedAccessType() {
    if (!(eventForm instanceof HTMLFormElement)) return "public";
    const data = new FormData(eventForm);
    return data.get("accessType") === "gated" ? "gated" : "public";
  }

  function isEditingEvent() {
    if (!(eventForm instanceof HTMLFormElement)) return false;
    const slug = eventForm.elements.namedItem("slug");
    return slug instanceof HTMLInputElement && Boolean(slug.value);
  }

  function syncSaveButtonLabel() {
    if (!(saveEventButton instanceof HTMLButtonElement)) return;
    if (isEditingEvent()) {
      saveEventButton.textContent = "Upravit akci";
      return;
    }

    saveEventButton.textContent = publishInput instanceof HTMLInputElement && publishInput.checked ? "Publikovat akci" : "Uložit koncept";
  }

  function syncAccessMode() {
    const gated = selectedAccessType() === "gated";
    if (gatedFields instanceof HTMLElement) gatedFields.hidden = !gated;
    for (const input of document.querySelectorAll("#gated-fields input, #gated-fields textarea")) {
      if (input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement) {
        input.required = gated && ["unlockCode", "secretLocationName", "secretLatitude", "secretLongitude", "secretInfo"].includes(input.name);
      }
    }
    syncSaveButtonLabel();
    renderEditorReadiness();
  }

  function resetEditor() {
    if (!(eventForm instanceof HTMLFormElement)) return;
    eventForm.reset();
    const slug = document.getElementById("slug");
    if (slug instanceof HTMLInputElement) slug.value = "";
    syncAccessMode();
    syncSaveButtonLabel();
    renderEditorReadiness();
    setStatus(formStatus, "Připraveno.", "neutral");
  }

  function fillEditor(item) {
    if (!(eventForm instanceof HTMLFormElement)) return;
    resetEditor();
    const fields = {
      slug: item.slug,
      title: item.title,
      startsAt: toLocalInputValue(item.startsAt),
      endAt: toLocalInputValue(item.endAt),
      publicLocation: item.publicLocation,
      publicLatitude: item.publicLatitude ?? "",
      publicLongitude: item.publicLongitude ?? "",
      summary: item.summary,
      genres: (item.genres || []).join(", "),
      lineup: (item.lineup || []).join(", "),
      tags: (item.tags || []).join(", "),
      galleryImageUrls: (item.galleryImageUrls || []).join(", "),
      coverImageUrl: item.coverImageUrl || "",
      externalUrl: item.externalUrl || "",
      simplexUrl: item.simplexUrl || "",
      sourceUrl: item.source?.url || "",
      sourceName: item.source?.name || "",
    };
    for (const [name, value] of Object.entries(fields)) {
      const field = eventForm.elements.namedItem(name);
      if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) field.value = value;
    }
    const published = eventForm.elements.namedItem("isPublished");
    if (published instanceof HTMLInputElement) published.checked = Boolean(item.isPublished);
    const access = eventForm.querySelector(`input[name="accessType"][value="${item.accessType || "public"}"]`);
    if (access instanceof HTMLInputElement) access.checked = true;
    syncAccessMode();
    syncSaveButtonLabel();
    renderEditorReadiness();
    setStatus(formStatus, `Upravuješ ${item.slug}. Uložení nahradí nejnovější Nostr událost pro tento slug.`, "warning");
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function filteredEvents() {
    const query = state.filters.query.trim().toLowerCase();
    const now = Date.now();
    return state.events.filter((item) => {
      const searchable = [
        item.title,
        item.slug,
        item.publicLocation,
        item.source?.name,
        item.source?.url,
        item.origin,
        item.crewSlug,
        item.crewName,
        item.externalUrl,
        ...(item.tags || []),
        ...(item.genres || []),
        ...(item.lineup || []),
      ]
        .filter(Boolean)
        .join(" ")
        .toLowerCase();

      const itemEnd = new Date(item.endAt || item.startsAt).getTime();
      const matchesQuery = !query || searchable.includes(query);
      const matchesStatus =
        state.filters.status === "all" ||
        (state.filters.status === "draft" && !item.isPublished) ||
        (state.filters.status === "live" && item.isPublished);
      const matchesAccess = state.filters.access === "all" || item.accessType === state.filters.access;
      const matchesSource =
        state.filters.source === "all" ||
        (state.filters.source === "community" && provenanceFor(item).key === "community") ||
        (state.filters.source === "crew" && provenanceFor(item).key === "crew") ||
        (state.filters.source === "imported" && provenanceFor(item).key === "import") ||
        (state.filters.source === "admin" && provenanceFor(item).key === "admin") ||
        (state.filters.source === "manual" && provenanceFor(item).key === "admin" && !item.source);
      const matchesTime =
        state.filters.time === "all" ||
        (state.filters.time === "upcoming" && itemEnd >= now) ||
        (state.filters.time === "past" && itemEnd < now) ||
        (state.filters.time === "missing-image" && !item.coverImageUrl);
      const matchesReview = matchesReviewFilter(item, state.filters.review);

      return matchesQuery && matchesStatus && matchesAccess && matchesSource && matchesTime && matchesReview;
    });
  }

  function badge(text, tone = "") {
    return `<span class="badge ${tone}">${text}</span>`;
  }

  function provenanceFor(item) {
    if (item.crewSlug || item.origin === "studio") return { key: "crew", label: "Crew", tone: "crew" };
    if (item.source || item.origin === "import") return { key: "import", label: "Import", tone: "import" };
    if (item.origin === "public" || (item.tags || []).includes("ravemap")) {
      return { key: "community", label: "Komunita", tone: "community" };
    }
    return { key: "admin", label: "Admin", tone: "admin" };
  }

  const REVIEW_FILTERS = [
    {
      key: "community",
      label: "Komunitní",
      description: "Veřejné příspěvky od lidí mimo crew/admin.",
    },
    {
      key: "drafts",
      label: "Koncepty",
      description: "Akce připravené k kontrole před publikací.",
    },
    {
      key: "missing-image",
      label: "Bez plakátu",
      description: "Publikace bez vizuálu nebo obrázku.",
    },
    {
      key: "upcoming-soon",
      label: "Brzy",
      description: "Akce začínající během 14 dní.",
    },
    {
      key: "past",
      label: "Minulé",
      description: "Akce po konci, vhodné ke kontrole nebo úklidu.",
    },
    {
      key: "gated",
      label: "Na kód",
      description: "Akce se zamčenou tajnou vrstvou.",
    },
    {
      key: "crew",
      label: "Crew",
      description: "Události napojené na crew profil.",
    },
  ];

  function eventEndTime(item) {
    return new Date(item.endAt || item.startsAt).getTime();
  }

  function isUpcomingSoon(item, now = Date.now()) {
    const start = new Date(item.startsAt).getTime();
    const horizon = now + 14 * 24 * 60 * 60 * 1000;
    return Number.isFinite(start) && start >= now && start <= horizon;
  }

  function matchesReviewFilter(item, reviewKey) {
    if (reviewKey === "all") return true;
    if (reviewKey === "community") return provenanceFor(item).key === "community";
    if (reviewKey === "drafts") return !item.isPublished;
    if (reviewKey === "missing-image") return !item.coverImageUrl;
    if (reviewKey === "upcoming-soon") return isUpcomingSoon(item);
    if (reviewKey === "past") return eventEndTime(item) < Date.now();
    if (reviewKey === "gated") return item.accessType === "gated";
    if (reviewKey === "crew") return provenanceFor(item).key === "crew";
    return true;
  }

  function reviewCount(key) {
    return state.events.filter((item) => matchesReviewFilter(item, key)).length;
  }

  function inventorySummary() {
    return {
      total: state.events.length,
      published: state.events.filter((item) => item.isPublished).length,
      drafts: state.events.filter((item) => !item.isPublished).length,
      community: state.events.filter((item) => provenanceFor(item).key === "community").length,
      crew: state.events.filter((item) => provenanceFor(item).key === "crew").length,
      imports: state.events.filter((item) => provenanceFor(item).key === "import").length,
      missingImage: state.events.filter((item) => !item.coverImageUrl).length,
    };
  }

  function resetFilterInputs() {
    if (eventFilter instanceof HTMLInputElement) eventFilter.value = "";
    if (statusFilter instanceof HTMLSelectElement) statusFilter.value = "all";
    if (accessFilter instanceof HTMLSelectElement) accessFilter.value = "all";
    if (sourceFilter instanceof HTMLSelectElement) sourceFilter.value = "all";
    if (timeFilter instanceof HTMLSelectElement) timeFilter.value = "all";
  }

  function clearFilters() {
    state.filters = {
      query: "",
      status: "all",
      access: "all",
      source: "all",
      time: "all",
      review: "all",
    };
    resetFilterInputs();
    renderDashboard();
    renderEvents();
  }

  function applyReviewFilter(key) {
    state.filters = {
      query: "",
      status: "all",
      access: "all",
      source: "all",
      time: "all",
      review: key,
    };
    resetFilterInputs();

    if (key === "community" && sourceFilter instanceof HTMLSelectElement) {
      state.filters.source = "community";
      sourceFilter.value = "community";
    }
    if (key === "crew" && sourceFilter instanceof HTMLSelectElement) {
      state.filters.source = "crew";
      sourceFilter.value = "crew";
    }
    if (key === "drafts" && statusFilter instanceof HTMLSelectElement) {
      state.filters.status = "draft";
      statusFilter.value = "draft";
    }
    if (key === "missing-image" && timeFilter instanceof HTMLSelectElement) {
      state.filters.time = "missing-image";
      timeFilter.value = "missing-image";
    }
    if (key === "past" && timeFilter instanceof HTMLSelectElement) {
      state.filters.time = "past";
      timeFilter.value = "past";
    }
    if (key === "gated" && accessFilter instanceof HTMLSelectElement) {
      state.filters.access = "gated";
      accessFilter.value = "gated";
    }

    renderDashboard();
    renderEvents();
    eventsTable?.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function renderDashboard() {
    const summary = inventorySummary();
    if (reviewSummary instanceof HTMLElement) {
      reviewSummary.innerHTML = [
        ["Celkem", summary.total],
        ["Publikováno", summary.published],
        ["Koncepty", summary.drafts],
        ["Komunita", summary.community],
        ["Crew", summary.crew],
        ["Import", summary.imports],
        ["Bez plakátu", summary.missingImage],
      ]
        .map(([label, value]) => `<span><strong>${escapeHtml(value)}</strong>${escapeHtml(label)}</span>`)
        .join("");
    }

    const queueMarkup = REVIEW_FILTERS.map((queue) => {
      const count = reviewCount(queue.key);
      return `
        <button type="button" class="review-card ${state.filters.review === queue.key ? "active" : ""}" data-review-filter="${escapeHtml(queue.key)}">
          <strong>${count}</strong>
          <span>${escapeHtml(queue.label)}</span>
          <small>${escapeHtml(queue.description)}</small>
        </button>
      `;
    }).join("");

    if (reviewQueues instanceof HTMLElement) reviewQueues.innerHTML = queueMarkup;
    if (quickFilters instanceof HTMLElement) {
      quickFilters.innerHTML =
        `<button type="button" data-review-filter="all" class="${state.filters.review === "all" ? "active" : ""}">Vše</button>` +
        REVIEW_FILTERS.map(
          (queue) =>
            `<button type="button" data-review-filter="${escapeHtml(queue.key)}" class="${state.filters.review === queue.key ? "active" : ""}">${escapeHtml(
              queue.label,
            )} <span>${reviewCount(queue.key)}</span></button>`,
        ).join("");
    }

    renderActiveFilters();
  }

  function renderActiveFilters() {
    if (!(activeFilters instanceof HTMLElement)) return;
    const chips = [];
    if (state.filters.review !== "all") {
      const review = REVIEW_FILTERS.find((item) => item.key === state.filters.review);
      chips.push(`Review: ${review?.label || state.filters.review}`);
    }
    if (state.filters.query) chips.push(`Hledání: ${state.filters.query}`);
    if (state.filters.status !== "all") chips.push(`Stav: ${state.filters.status === "draft" ? "Koncepty" : "Publikované"}`);
    if (state.filters.access !== "all") chips.push(`Přístup: ${state.filters.access === "gated" ? "Na kód" : "Veřejné"}`);
    if (state.filters.source !== "all") chips.push(`Původ: ${sourceFilter instanceof HTMLSelectElement ? sourceFilter.selectedOptions[0]?.textContent || state.filters.source : state.filters.source}`);
    if (state.filters.time !== "all") chips.push(`Čas: ${timeFilter instanceof HTMLSelectElement ? timeFilter.selectedOptions[0]?.textContent || state.filters.time : state.filters.time}`);

    activeFilters.innerHTML =
      chips.length === 0
        ? `<span>Žádný filtr aktivní.</span>`
        : chips.map((chip) => `<span>${escapeHtml(chip)}</span>`).join("") + `<button type="button" data-clear-filters>Vyčistit</button>`;
  }

  function eventDateRange(item) {
    const start = dateFormatter.format(new Date(item.startsAt));
    return item.endAt ? `${start} -> ${dateFormatter.format(new Date(item.endAt))}` : start;
  }

  function compactList(values, max = 4) {
    const list = (values || []).filter(Boolean);
    if (list.length <= max) return list.join(", ");
    return `${list.slice(0, max).join(", ")} +${list.length - max}`;
  }

  function syncBulkControls(rows) {
    const selectedRows = state.events.filter((item) => state.selectedSlugs.has(item.slug));
    const selectedDrafts = selectedRows.filter((item) => !item.isPublished);
    const allFilteredSelected = rows.length > 0 && rows.every((item) => state.selectedSlugs.has(item.slug));

    if (inventoryCount instanceof HTMLElement) inventoryCount.textContent = `${rows.length} zobrazeno / ${state.events.length} celkem`;
    if (selectedCount instanceof HTMLElement) {
      const draftText = selectedDrafts.length > 0 ? ` / ${selectedDrafts.length} konceptů` : "";
      selectedCount.textContent = `${selectedRows.length} vybráno${draftText}`;
    }
    if (bulkPublishButton instanceof HTMLButtonElement) bulkPublishButton.disabled = selectedDrafts.length === 0;
    if (bulkDeleteButton instanceof HTMLButtonElement) bulkDeleteButton.disabled = selectedRows.length === 0;
    if (clearSelectionButton instanceof HTMLButtonElement) clearSelectionButton.disabled = selectedRows.length === 0;
    if (selectFiltered instanceof HTMLInputElement) {
      selectFiltered.checked = allFilteredSelected;
      selectFiltered.indeterminate = !allFilteredSelected && rows.some((item) => state.selectedSlugs.has(item.slug));
    }
  }

  function renderEvents() {
    if (!(eventsTable instanceof HTMLElement)) return;
    const rows = filteredEvents();
    if (eventCount instanceof HTMLElement) eventCount.textContent = String(state.events.length);
    syncBulkControls(rows);
    renderActiveFilters();
    if (rows.length === 0) {
      eventsTable.innerHTML = `<p class="empty-state">Nic neodpovídá filtru.</p>`;
      return;
    }

    const header = `
      <div class="event-table-head" role="row">
        <span></span>
        <span>Plakát</span>
        <span>Ovládání</span>
        <span>Datum</span>
        <span>Lokalita</span>
        <span>Původ</span>
        <span>Stav</span>
        <span>Akce</span>
      </div>
    `;

    eventsTable.innerHTML =
      header +
      rows
        .map((item, index) => {
        const provenance = provenanceFor(item);
        const provenanceBadge = badge(provenance.label, provenance.tone);
        const liveBadge = item.isPublished ? badge("publikováno", "live") : badge("koncept", "draft");
        const accessBadge = item.accessType === "gated" ? badge("na kód", "danger") : badge("veřejná", "soft");
        const timeBadge = eventEndTime(item) < Date.now() ? badge("minulá", "soft") : isUpcomingSoon(item) ? badge("brzy", "warning") : "";
        const imageBadge = item.coverImageUrl ? "" : badge("bez plakátu", "warning");
        const sourceLine = item.source?.url
          ? `<a href="${escapeHtml(item.source.url)}" target="_blank" rel="noreferrer">zdroj</a>`
          : provenance.key === "community"
            ? "komunitní formulář"
            : provenance.key === "crew"
              ? escapeHtml(item.crewName || item.crewSlug || "crew")
              : "admin";
        const thumb = item.coverImageUrl
          ? `<img class="event-thumb" src="${escapeHtml(item.coverImageUrl)}" alt="" loading="lazy" decoding="async" referrerpolicy="no-referrer" />`
          : `<span class="event-thumb-empty" aria-hidden="true"></span>`;
        const tags = compactList([...(item.tags || []), ...(item.genres || [])]);
        const selected = state.selectedSlugs.has(item.slug);
        return `
          <article class="event-row ${selected ? "selected" : ""}" data-index="${index}">
            <label class="row-select" aria-label="Vybrat ${escapeHtml(item.title)}">
              <input type="checkbox" data-action="select" data-slug="${escapeHtml(item.slug)}" ${selected ? "checked" : ""} />
            </label>
            ${thumb}
            <div class="event-main">
              <strong>${escapeHtml(item.title)}</strong>
              <span class="slug">${escapeHtml(item.slug)}</span>
              <p>${escapeHtml(String(item.summary || "").slice(0, 260))}</p>
            </div>
            <div class="event-when">${escapeHtml(eventDateRange(item))}</div>
            <div class="event-place">${escapeHtml(item.publicLocation || "Neznámá")}</div>
            <div class="event-source">
              <span>${sourceLine}</span>
              ${tags ? `<small>${escapeHtml(tags)}</small>` : ""}
            </div>
            <div class="badges">${liveBadge}${accessBadge}${provenanceBadge}${timeBadge}${imageBadge}</div>
            <div class="row-actions">
              <button type="button" data-action="edit" data-slug="${escapeHtml(item.slug)}">Upravit</button>
              ${!item.isPublished ? `<button type="button" data-action="publish" data-slug="${escapeHtml(item.slug)}">Publikovat</button>` : `<a href="/akce/${escapeHtml(item.slug)}" target="_blank" rel="noreferrer">Otevřít</a>`}
              <button type="button" data-action="delete" data-slug="${escapeHtml(item.slug)}">Smazat</button>
            </div>
          </article>
        `;
        })
        .join("");
  }

  async function loadEvents() {
    const response = await fetch("/api/admin/events", { headers: adminHeaders() });
    const data = await parseResponse(response);
    state.events = Array.isArray(data.events) ? data.events : [];
    const knownSlugs = new Set(state.events.map((item) => item.slug));
    for (const slug of [...state.selectedSlugs]) {
      if (!knownSlugs.has(slug)) state.selectedSlugs.delete(slug);
    }
    renderDashboard();
    renderEvents();
  }

  function editorPayloadSnapshot() {
    if (!(eventForm instanceof HTMLFormElement)) return null;
    const data = new FormData(eventForm);
    const accessType = selectedAccessType();
    return {
      title: String(data.get("title") || "").trim(),
      startsAt: String(data.get("startsAt") || "").trim(),
      publicLocation: String(data.get("publicLocation") || "").trim(),
      summary: String(data.get("summary") || "").trim(),
      coverImageUrl: String(data.get("coverImageUrl") || "").trim(),
      accessType,
      unlockCode: String(data.get("unlockCode") || "").trim(),
      secretLocationName: String(data.get("secretLocationName") || "").trim(),
      secretLatitude: String(data.get("secretLatitude") || "").trim(),
      secretLongitude: String(data.get("secretLongitude") || "").trim(),
      secretInfo: String(data.get("secretInfo") || "").trim(),
      editing: isEditingEvent(),
    };
  }

  function renderEditorReadiness() {
    if (!(editorReadiness instanceof HTMLElement)) return;
    const payload = editorPayloadSnapshot();
    if (!payload) return;
    const missing = [];
    if (!payload.title) missing.push("název");
    if (!payload.startsAt) missing.push("datum");
    if (!payload.publicLocation) missing.push("lokalita");
    if (payload.summary.length < 10) missing.push("popis");
    const hints = [];
    if (!payload.coverImageUrl) hints.push("bez plakátu");
    if (payload.accessType === "gated") {
      const secretComplete =
        payload.unlockCode &&
        payload.secretLocationName &&
        payload.secretLatitude &&
        payload.secretLongitude &&
        payload.secretInfo;
      hints.push(secretComplete || payload.editing ? "na kód" : "chybí tajná vrstva");
    } else {
      hints.push("veřejná");
    }

    if (missing.length > 0) {
      setStatus(editorReadiness, `Chybí: ${missing.join(", ")}.`, "warning");
      return;
    }
    if (hints.includes("chybí tajná vrstva")) {
      setStatus(editorReadiness, "Gated akce potřebuje kód, tajnou lokaci, souřadnice a info.", "danger");
      return;
    }
    setStatus(editorReadiness, `Připraveno: ${hints.join(" / ")}.`, hints.includes("bez plakátu") ? "warning" : "positive");
  }

  function renderCrews() {
    if (!(crewList instanceof HTMLElement)) return;
    if (state.crews.length === 0) {
      crewList.innerHTML = `<p class="empty-state">Zatím žádné crew profily.</p>`;
      return;
    }

    crewList.innerHTML = state.crews
      .map(
        (crew) => `
          <article class="preview-item">
            <strong>${escapeHtml(crew.name)} ${crew.archived ? "(archiv)" : ""}</strong>
            <span>${escapeHtml(crew.slug)}</span>
            <small>${escapeHtml(crew.lightningAddress || "bez lightning adresy")}</small>
            <p>${escapeHtml(crew.summary)}</p>
            <button type="button" data-crew-fill="${escapeHtml(crew.slug)}">Upravit</button>
          </article>
        `,
      )
      .join("");
  }

  async function loadCrews() {
    const response = await fetch("/api/admin/crews", { headers: adminHeaders() });
    const data = await parseResponse(response);
    state.crews = Array.isArray(data.crews) ? data.crews : [];
    renderCrews();
  }

  function crewPayload(action) {
    if (!(crewForm instanceof HTMLFormElement)) throw new Error("Crew formulář není dostupný.");
    const data = new FormData(crewForm);
    return {
      action,
      slug: String(data.get("slug") || "").trim().toLowerCase(),
      crewCode: String(data.get("crewCode") || "").trim() || undefined,
      name: String(data.get("name") || "").trim() || undefined,
      summary: String(data.get("summary") || "").trim() || undefined,
      avatarUrl: String(data.get("avatarUrl") || "").trim() || undefined,
      bannerUrl: String(data.get("bannerUrl") || "").trim() || undefined,
      simplexUrl: String(data.get("simplexUrl") || "").trim() || undefined,
      websiteUrl: String(data.get("websiteUrl") || "").trim() || undefined,
      lightningAddress: String(data.get("lightningAddress") || "").trim() || undefined,
    };
  }

  async function sendCrewAction(payload, successMessage) {
    setStatus(crewStatus, "Ukládám crew změnu...", "warning");
    const response = await fetch("/api/admin/crews", {
      method: "POST",
      headers: adminHeaders(true),
      body: JSON.stringify(payload),
    });
    await parseResponse(response);
    setStatus(crewStatus, successMessage, "positive");
    await Promise.all([loadCrews(), loadEvents()]);
  }

  function fillCrewForm(crew) {
    if (!(crewForm instanceof HTMLFormElement)) return;
    const fields = {
      slug: crew.slug,
      name: crew.name,
      summary: crew.summary,
      avatarUrl: crew.avatarUrl || "",
      bannerUrl: crew.bannerUrl || "",
      simplexUrl: crew.simplexUrl || "",
      websiteUrl: crew.websiteUrl || "",
      lightningAddress: crew.lightningAddress || "",
      crewCode: "",
    };
    for (const [name, value] of Object.entries(fields)) {
      const field = crewForm.elements.namedItem(name);
      if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) field.value = value;
    }
    const code = crewCodeInput();
    if (code) code.type = "password";
  }

  function crewCodeInput() {
    if (!(crewForm instanceof HTMLFormElement)) return null;
    const field = crewForm.elements.namedItem("crewCode");
    return field instanceof HTMLInputElement ? field : null;
  }

  function generateSafeCode() {
    const bytes = new Uint8Array(24);
    if (!window.crypto?.getRandomValues) {
      throw new Error("Prohlížeč neumí bezpečné generování kódu.");
    }

    window.crypto.getRandomValues(bytes);
    const binary = Array.from(bytes, (byte) => String.fromCharCode(byte)).join("");
    return window.btoa(binary).replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/g, "");
  }

  function setGeneratedCrewCode() {
    const input = crewCodeInput();
    if (!input) return;
    input.value = generateSafeCode();
    input.type = "text";
    input.focus();
    input.select();
    setStatus(crewStatus, "Bezpečný crew kód je vygenerovaný. Zkopíruj ho před uložením nebo rotací.", "warning");
  }

  async function copyCrewCode() {
    const input = crewCodeInput();
    const value = input?.value.trim();
    if (!value) {
      setStatus(crewStatus, "Nejdřív vygeneruj nebo vyplň crew kód.", "warning");
      return;
    }

    await navigator.clipboard.writeText(value);
    setStatus(crewStatus, "Crew kód zkopírován.", "positive");
  }

  function crewSlugValue() {
    if (!(crewForm instanceof HTMLFormElement)) return "";
    const field = crewForm.elements.namedItem("slug");
    return field instanceof HTMLInputElement ? field.value.trim().toLowerCase() : "";
  }

  function crewNameValue() {
    if (!(crewForm instanceof HTMLFormElement)) return "";
    const field = crewForm.elements.namedItem("name");
    return field instanceof HTMLInputElement ? field.value.trim() : "";
  }

  function crewInviteText(slug, code) {
    const origin = window.location.origin;
    const name = crewNameValue() || slug;
    return [
      `RaveMap Studio pozvánka pro ${name}`,
      "",
      `Studio: ${origin}/studio`,
      `Crew profil: ${origin}/crew/${slug}`,
      `Crew slug: ${slug}`,
      `Crew kód: ${code}`,
      "",
      "Kód si uložte bezpečně. V této záložce se nepersistuje a admin ho může později rotovat.",
    ].join("\n");
  }

  async function copyCrewInvite() {
    const slug = crewSlugValue();
    const code = crewCodeInput()?.value.trim() || "";
    if (!slug) {
      setStatus(crewStatus, "Nejdřív vyplň crew slug.", "warning");
      return;
    }
    if (!code) {
      setGeneratedCrewCode();
      setStatus(crewStatus, "Vygeneroval jsem kód. Zkontroluj ho a zkopíruj pozvánku znovu.", "warning");
      return;
    }

    await navigator.clipboard.writeText(crewInviteText(slug, code));
    setStatus(crewStatus, "Crew pozvánka zkopírována. Pošli ji jen důvěryhodnému kontaktu.", "positive");
  }

  async function loadDiagnostics() {
    if (!(diagnostics instanceof HTMLElement)) return;
    const response = await fetch("/api/admin/diagnostics", { headers: adminHeaders() });
    const data = await parseResponse(response);
    const okCount = data.checks?.relays?.filter((relay) => relay.ok).length || 0;
    if (relayState instanceof HTMLElement) relayState.textContent = `${okCount}/${data.relays?.length || 0} ok`;
    diagnostics.innerHTML = `
      <p><strong>Publikuje</strong><br>${escapeHtml(data.publisherPubkey)}</p>
      <p><strong>Quorum zápisu</strong><br>${escapeHtml(data.writeMinSuccess)}</p>
      ${(data.checks?.relays || [])
        .map(
          (relay) =>
            `<p>${relay.ok ? "OK" : "CHYBA"} ${escapeHtml(relay.relay)}<br><small>${escapeHtml(
              relay.message || `${relay.events} akcí`,
            )}</small></p>`,
        )
        .join("")}
    `;
  }

  async function authenticate() {
    setBusy(unlockButton, true);
    setStatus(authStatus, "Ověřuji kód...", "warning");
    try {
      await Promise.all([loadEvents(), loadCrews()]);
      state.authenticated = true;
      if (accessGate instanceof HTMLElement) accessGate.hidden = true;
      if (workspace instanceof HTMLElement) workspace.hidden = false;
      if (authState instanceof HTMLElement) authState.textContent = "Odemčeno";
      setStatus(globalStatus, "Pracovní plocha načtena.", "positive");
      loadDiagnostics().catch((error) => {
        if (relayState instanceof HTMLElement) relayState.textContent = "Kontrola selhala";
        setStatus(globalStatus, error instanceof Error ? error.message : "Diagnostika relayů selhala.", "warning");
      });
    } catch (error) {
      setStatus(authStatus, error instanceof Error ? error.message : "Ověření selhalo.", "danger");
    } finally {
      setBusy(unlockButton, false);
    }
  }

  function clearAdminSession() {
    if (adminSecretInput instanceof HTMLInputElement) adminSecretInput.value = "";
    state.authenticated = false;
    if (workspace instanceof HTMLElement) workspace.hidden = true;
    if (accessGate instanceof HTMLElement) accessGate.hidden = false;
    if (authState instanceof HTMLElement) authState.textContent = "Zamčeno";
    setStatus(authStatus, "Admin kód vymazán z této záložky.", "neutral");
  }

  async function saveEvent(event) {
    event.preventDefault();
    if (!(eventForm instanceof HTMLFormElement)) return;
    const data = new FormData(eventForm);
    const accessType = selectedAccessType();
    const payload = {
      slug: String(data.get("slug") || "").trim() || undefined,
      title: String(data.get("title") || ""),
      startsAt: toIsoFromLocal(String(data.get("startsAt") || "")),
      endAt: toIsoFromLocal(String(data.get("endAt") || "")),
      publicLocation: String(data.get("publicLocation") || ""),
      publicLatitude: data.get("publicLatitude") ? Number(data.get("publicLatitude")) : undefined,
      publicLongitude: data.get("publicLongitude") ? Number(data.get("publicLongitude")) : undefined,
      summary: String(data.get("summary") || ""),
      coverImageUrl: String(data.get("coverImageUrl") || "").trim() || undefined,
      externalUrl: String(data.get("externalUrl") || "").trim() || undefined,
      simplexUrl: String(data.get("simplexUrl") || "").trim() || undefined,
      sourceUrl: String(data.get("sourceUrl") || "").trim() || undefined,
      sourceName: String(data.get("sourceName") || "").trim() || undefined,
      genres: listFromInput(data.get("genres")),
      lineup: listFromInput(data.get("lineup")),
      tags: listFromInput(data.get("tags")),
      galleryImageUrls: listFromInput(data.get("galleryImageUrls")),
      accessType,
      isPublished: data.get("isPublished") === "on",
      unlockCode: accessType === "gated" ? String(data.get("unlockCode") || "") : undefined,
      secretLocationName: accessType === "gated" ? String(data.get("secretLocationName") || "") : undefined,
      secretLatitude: accessType === "gated" ? Number(data.get("secretLatitude")) : undefined,
      secretLongitude: accessType === "gated" ? Number(data.get("secretLongitude")) : undefined,
      secretInfo: accessType === "gated" ? String(data.get("secretInfo") || "") : undefined,
      secretMapNote: accessType === "gated" ? String(data.get("secretMapNote") || "").trim() || undefined : undefined,
    };

    setStatus(formStatus, "Ukládám akci na Nostr relaye...", "warning");
    try {
      const response = await fetch("/api/admin/events", {
        method: "POST",
        headers: adminHeaders(true),
        body: JSON.stringify(payload),
      });
      const saved = await parseResponse(response);
      setStatus(formStatus, `Uloženo ${saved.slug}.`, "positive");
      resetEditor();
      await loadEvents();
    } catch (error) {
      setStatus(formStatus, error instanceof Error ? error.message : "Uložení selhalo.", "danger");
    }
  }

  async function previewImport() {
    setBusy(previewImportButton, true);
    setStatus(importStatus, "Načítám náhled zdroje...", "warning");
    try {
      const response = await fetch("/api/admin/imports/jiripetrak/preview", { headers: adminHeaders() });
      const data = await parseResponse(response);
      if (importState instanceof HTMLElement) importState.textContent = `${data.events.length} nalezeno`;
      if (importPreview instanceof HTMLElement) {
        importPreview.hidden = false;
        importPreview.innerHTML = data.events
          .slice(0, 12)
          .map(
            (item) => `
              <article class="preview-item">
                <strong>${escapeHtml(item.title)}</strong>
                <span>${escapeHtml(eventDateRange(item))}</span>
                <small>${escapeHtml(item.publicLocation || "Neznámá lokalita")}</small>
                <p>${escapeHtml(String(item.summary || "").slice(0, 420))}</p>
                <small>${escapeHtml([...(item.tags || []), ...(item.genres || [])].join(", "))}</small>
                <small>${escapeHtml(item.sourceUrl)}</small>
              </article>
            `,
          )
          .join("");
      }
      setStatus(importStatus, `Náhled načetl ${data.events.length} akcí.`, "positive");
    } catch (error) {
      setStatus(importStatus, error instanceof Error ? error.message : "Náhled importu selhal.", "danger");
    } finally {
      setBusy(previewImportButton, false);
    }
  }

  async function syncImport() {
    setBusy(syncImportButton, true);
    setStatus(importStatus, "Synchronizuji importované koncepty...", "warning");
    try {
      const response = await fetch("/api/admin/imports/jiripetrak/sync", {
        method: "POST",
        headers: adminHeaders(),
      });
      const data = await parseResponse(response);
      if (importState instanceof HTMLElement) {
        importState.textContent = `${data.created} nových / ${data.updated} upraveno / ${data.pending || 0} čeká`;
      }
      const pendingText = data.pending ? ` ${data.pending} dalších čeká, spusť synchronizaci znovu.` : "";
      setStatus(
        importStatus,
        `Zpracováno ${data.created + data.updated} změn z ${data.imported} akcí.${pendingText}`,
        data.pending ? "warning" : "positive",
      );
      await loadEvents();
    } catch (error) {
      setStatus(importStatus, error instanceof Error ? error.message : "Synchronizace importu selhala.", "danger");
    } finally {
      setBusy(syncImportButton, false);
    }
  }

  async function publishSlug(slug) {
    const response = await fetch("/api/admin/events", {
      method: "PATCH",
      headers: adminHeaders(true),
      body: JSON.stringify({ slug, action: "publish" }),
    });
    await parseResponse(response);
  }

  async function deleteSlug(slug) {
    const response = await fetch("/api/admin/events", {
      method: "DELETE",
      headers: adminHeaders(true),
      body: JSON.stringify({ slug, confirmSlug: slug }),
    });
    await parseResponse(response);
  }

  async function bulkPublishSelected() {
    const selectedDrafts = state.events.filter((item) => state.selectedSlugs.has(item.slug) && !item.isPublished);
    if (selectedDrafts.length === 0) return;

    setStatus(globalStatus, `Publikuji ${selectedDrafts.length} konceptů...`, "warning");
    setBusy(bulkPublishButton, true);
    try {
      for (const item of selectedDrafts) {
        await publishSlug(item.slug);
      }
      setStatus(globalStatus, `Publikováno ${selectedDrafts.length} konceptů.`, "positive");
      await loadEvents();
    } catch (error) {
      setStatus(globalStatus, error instanceof Error ? error.message : "Hromadné publikování selhalo.", "danger");
    } finally {
      setBusy(bulkPublishButton, false);
      renderEvents();
    }
  }

  async function bulkDeleteSelected() {
    const selectedRows = state.events.filter((item) => state.selectedSlugs.has(item.slug));
    if (selectedRows.length === 0) return;

    const sample = selectedRows
      .slice(0, 5)
      .map((item) => item.slug)
      .join(", ");
    const extra = selectedRows.length > 5 ? `, +${selectedRows.length - 5} dalších` : "";
    const confirmation = window.prompt(
      `Smazání vytvoří Nostr tombstone pro ${selectedRows.length} akcí: ${sample}${extra}.\nNapiš SMAZAT ${selectedRows.length} pro pokračování.`,
    );
    if (confirmation !== `SMAZAT ${selectedRows.length}`) return;

    setStatus(globalStatus, `Mažu ${selectedRows.length} akcí...`, "warning");
    setBusy(bulkDeleteButton, true);
    try {
      for (const item of selectedRows) {
        await deleteSlug(item.slug);
        state.selectedSlugs.delete(item.slug);
      }
      setStatus(globalStatus, `Smazáno ${selectedRows.length} akcí.`, "positive");
      await loadEvents();
    } catch (error) {
      setStatus(globalStatus, error instanceof Error ? error.message : "Hromadné mazání selhalo.", "danger");
    } finally {
      setBusy(bulkDeleteButton, false);
      renderEvents();
    }
  }

  async function handleEventAction(event) {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const action = target.dataset.action;
    const slug = target.dataset.slug;
    if (!action || !slug) return;
    const item = state.events.find((candidate) => candidate.slug === slug);
    if (!item) return;

    if (action === "select") {
      if (target instanceof HTMLInputElement && target.checked) {
        state.selectedSlugs.add(slug);
      } else {
        state.selectedSlugs.delete(slug);
      }
      renderEvents();
      return;
    }

    if (action === "edit") {
      fillEditor(item);
      return;
    }

    try {
      if (action === "publish") {
        await publishSlug(slug);
        setStatus(globalStatus, `Publikováno ${slug}.`, "positive");
      }

      if (action === "delete") {
        const confirmSlug = window.prompt(`Smazání vytvoří Nostr tombstone a skryje akci z RaveMap.\nNapiš slug pro smazání: ${slug}`);
        if (confirmSlug !== slug) return;
        await deleteSlug(slug);
        state.selectedSlugs.delete(slug);
        setStatus(globalStatus, `Smazáno ${slug}.`, "positive");
      }

      await loadEvents();
    } catch (error) {
      setStatus(globalStatus, error instanceof Error ? error.message : `Akce ${action} selhala.`, "danger");
    }
  }

  for (const input of document.querySelectorAll('input[name="accessType"]')) {
    input.addEventListener("change", syncAccessMode);
  }
  syncAccessMode();
  publishInput?.addEventListener("change", syncSaveButtonLabel);

  accessForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    authenticate();
  });
  clearAdminSecretButton?.addEventListener("click", clearAdminSession);
  crewForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    try {
      const payload = crewPayload("upsert");
      const existing = state.crews.some((crew) => crew.slug === payload.slug);
      if (!existing && !payload.crewCode) {
        setGeneratedCrewCode();
        return;
      }

      await sendCrewAction(payload, "Crew profil uložen.");
    } catch (error) {
      setStatus(crewStatus, error instanceof Error ? error.message : "Uložení crew selhalo.", "danger");
    }
  });
  rotateCrewCodeButton?.addEventListener("click", async () => {
    try {
      if (!crewCodeInput()?.value.trim()) {
        setGeneratedCrewCode();
        return;
      }
      const slug = crewSlugValue();
      if (!slug || !window.confirm(`Rotovat Studio kód pro crew ${slug}? Starý kód přestane fungovat po propsání na relaye.`)) return;
      await sendCrewAction(crewPayload("rotate-code"), "Crew kód změněn.");
    } catch (error) {
      setStatus(crewStatus, error instanceof Error ? error.message : "Rotace kódu selhala.", "danger");
    }
  });
  generateCrewCodeButton?.addEventListener("click", () => {
    try {
      setGeneratedCrewCode();
    } catch (error) {
      setStatus(crewStatus, error instanceof Error ? error.message : "Generování kódu selhalo.", "danger");
    }
  });
  copyCrewCodeButton?.addEventListener("click", async () => {
    try {
      await copyCrewCode();
    } catch (error) {
      setStatus(crewStatus, error instanceof Error ? error.message : "Kopírování kódu selhalo.", "danger");
    }
  });
  copyCrewInviteButton?.addEventListener("click", async () => {
    try {
      await copyCrewInvite();
    } catch (error) {
      setStatus(crewStatus, error instanceof Error ? error.message : "Kopírování pozvánky selhalo.", "danger");
    }
  });
  archiveCrewButton?.addEventListener("click", async () => {
    const payload = crewPayload("archive");
    if (!payload.slug || !window.confirm(`Archivovat crew ${payload.slug}? Profil zůstane v historii, ale crew nebude běžně aktivní pro handoff.`)) return;
    try {
      await sendCrewAction(payload, "Crew archivována.");
    } catch (error) {
      setStatus(crewStatus, error instanceof Error ? error.message : "Archivace crew selhala.", "danger");
    }
  });
  assignCrewForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(assignCrewForm instanceof HTMLFormElement)) return;
    const data = new FormData(assignCrewForm);
    try {
      await sendCrewAction(
        {
          action: "assign-event",
          slug: String(data.get("crewSlug") || "").trim().toLowerCase(),
          eventSlug: String(data.get("eventSlug") || "").trim().toLowerCase(),
        },
        "Akce přiřazena crew.",
      );
    } catch (error) {
      setStatus(crewStatus, error instanceof Error ? error.message : "Přiřazení selhalo.", "danger");
    }
  });
  reloadCrewsButton?.addEventListener("click", async () => {
    try {
      await loadCrews();
    } catch (error) {
      setStatus(crewStatus, error instanceof Error ? error.message : "Načtení crew selhalo.", "danger");
    }
  });
  crewList?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const slug = target.dataset.crewFill;
    const crew = slug ? state.crews.find((item) => item.slug === slug) : null;
    if (crew) fillCrewForm(crew);
  });
  eventForm?.addEventListener("submit", saveEvent);
  resetFormButton?.addEventListener("click", resetEditor);
  reloadEventsButton?.addEventListener("click", async () => {
    await loadEvents();
  });
  reloadDiagnosticsButton?.addEventListener("click", async () => {
    await loadDiagnostics();
  });
  previewImportButton?.addEventListener("click", previewImport);
  syncImportButton?.addEventListener("click", syncImport);
  eventsTable?.addEventListener("click", handleEventAction);
  reviewQueues?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest("[data-review-filter]");
    if (!(button instanceof HTMLElement)) return;
    applyReviewFilter(button.dataset.reviewFilter || "all");
  });
  quickFilters?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest("[data-review-filter]");
    if (!(button instanceof HTMLElement)) return;
    applyReviewFilter(button.dataset.reviewFilter || "all");
  });
  activeFilters?.addEventListener("click", (event) => {
    const target = event.target;
    if (target instanceof HTMLElement && target.dataset.clearFilters !== undefined) {
      clearFilters();
    }
  });
  clearReviewFiltersButton?.addEventListener("click", clearFilters);
  eventForm?.addEventListener("input", renderEditorReadiness);
  eventFilter?.addEventListener("input", () => {
    state.filters.review = "all";
    state.filters.query = eventFilter instanceof HTMLInputElement ? eventFilter.value : "";
    renderDashboard();
    renderEvents();
  });
  statusFilter?.addEventListener("change", () => {
    state.filters.review = "all";
    state.filters.status = statusFilter instanceof HTMLSelectElement ? statusFilter.value : "all";
    renderDashboard();
    renderEvents();
  });
  accessFilter?.addEventListener("change", () => {
    state.filters.review = "all";
    state.filters.access = accessFilter instanceof HTMLSelectElement ? accessFilter.value : "all";
    renderDashboard();
    renderEvents();
  });
  sourceFilter?.addEventListener("change", () => {
    state.filters.review = "all";
    state.filters.source = sourceFilter instanceof HTMLSelectElement ? sourceFilter.value : "all";
    renderDashboard();
    renderEvents();
  });
  timeFilter?.addEventListener("change", () => {
    state.filters.review = "all";
    state.filters.time = timeFilter instanceof HTMLSelectElement ? timeFilter.value : "all";
    renderDashboard();
    renderEvents();
  });
  selectFiltered?.addEventListener("change", () => {
    const rows = filteredEvents();
    const checked = selectFiltered instanceof HTMLInputElement && selectFiltered.checked;
    for (const item of rows) {
      if (checked) {
        state.selectedSlugs.add(item.slug);
      } else {
        state.selectedSlugs.delete(item.slug);
      }
    }
    renderEvents();
  });
  clearSelectionButton?.addEventListener("click", () => {
    state.selectedSlugs.clear();
    renderEvents();
  });
  bulkPublishButton?.addEventListener("click", bulkPublishSelected);
  bulkDeleteButton?.addEventListener("click", bulkDeleteSelected);
</script>

