---
export const prerender = false;

import { and, eq } from "drizzle-orm";
import Layout from "../../layouts/Layout.astro";
import { db } from "../../db/client";
import { events } from "../../db/schema";

const slug = Astro.params.slug?.trim().toLowerCase() ?? "";
const slugValid = /^[a-z0-9-]{3,120}$/.test(slug);

const rows = slugValid
  ? await db
      .select({
        slug: events.slug,
        title: events.title,
        summary: events.summary,
        publicLocation: events.publicLocation,
        startsAt: events.startsAt,
        coverImageUrl: events.coverImageUrl,
      })
      .from(events)
      .where(and(eq(events.slug, slug), eq(events.isPublished, true)))
      .limit(1)
  : [];

const event = rows[0] ?? null;
if (!event) {
  Astro.response.status = 404;
}

const formatter = new Intl.DateTimeFormat("cs-CZ", {
  dateStyle: "full",
  timeStyle: "short",
});
---

<Layout bodyClass="event-body">
  <div class="event-shell">
    <div class="event-grid-canvas">
      <span class="v" style="--x: 18%; --w: 3px;"></span>
      <span class="v" style="--x: 64%; --w: 3px;"></span>
      <span class="h" style="--y: 28%; --w: 3px;"></span>
      <span class="h" style="--y: 62%; --w: 3px;"></span>
    </div>
    <div class="event-bg"></div>
    <img src="/bunkr.png" class="bunkr" alt="Decorative bunker" />

    {
      !event ? (
        <div class="event-layout event-layout-missing">
          <a class="back-link" href="/#akce">Zpět na akce</a>
          <article class="event-card public-card">
            <p class="card-kicker">AKCE</p>
            <h1>Akce nenalezena</h1>
            <p class="card-copy">Tenhle odkaz už neexistuje nebo akce ještě není publikovaná.</p>
          </article>
        </div>
      ) : (
        <div class="event-layout">
          <div class="event-topbar">
            <a class="back-link" href="/#akce">Zpět na akce</a>
            <span class="event-slug">{event.slug}</span>
          </div>

          <article class="event-card public-card">
            <div class="card-head">
              <p class="card-kicker">PUBLIC</p>
              <div class="meta-pills">
                <span class="meta-pill">PUBLISHED</span>
                <span class="meta-pill meta-pill-soft">{event.publicLocation}</span>
              </div>
            </div>

            <img
              class="event-cover"
              src={event.coverImageUrl || "/bunkr.png"}
              alt={event.title}
            />
            <h1>{event.title}</h1>
            <p class="event-date">{formatter.format(event.startsAt)}</p>
            <p class="card-copy">{event.summary}</p>
          </article>

          <article class="event-card secret-card">
            <div class="card-head">
              <p class="card-kicker">SECRET</p>
              <span id="secret-state" class="meta-pill">LOCKED</span>
            </div>

            <form id="unlock-form" class="unlock-form" data-slug={event.slug}>
              <label class="unlock-field" for="unlockCode">
                <span class="unlock-label">Unlock kód</span>
                <input
                  id="unlockCode"
                  class="secret-input"
                  name="unlockCode"
                  type="password"
                  placeholder="SECRET KOD"
                  minlength="8"
                  maxlength="128"
                  required
                />
              </label>
              <button class="secret-button" type="submit">ODEMKNOUT</button>
            </form>

            <p id="unlock-message" class="unlock-message" role="status" aria-live="polite"></p>

            <div id="secret-content" class="secret-content" hidden>
              <div class="secret-block">
                <span class="secret-label">Lokace</span>
                <h2 id="secret-location"></h2>
              </div>
              <div class="secret-block">
                <span class="secret-label">Info</span>
                <p id="secret-info"></p>
              </div>
              <div class="secret-block secret-note-block" id="secret-note-wrap" hidden>
                <span class="secret-label">Poznámka</span>
                <p id="secret-note"></p>
              </div>
              <iframe
                id="secret-map"
                title="Mapa tajné lokace"
                loading="lazy"
                referrerpolicy="no-referrer"
                width="100%"
                height="320"
              ></iframe>
            </div>
          </article>
        </div>
      )
    }
  </div>
</Layout>

<script>
  const form = document.getElementById("unlock-form");
  if (form instanceof HTMLFormElement) {
    const input = document.getElementById("unlockCode");
    const message = document.getElementById("unlock-message");
    const content = document.getElementById("secret-content");
    const locationEl = document.getElementById("secret-location");
    const infoEl = document.getElementById("secret-info");
    const noteEl = document.getElementById("secret-note");
    const noteWrap = document.getElementById("secret-note-wrap");
    const mapEl = document.getElementById("secret-map");
    const secretState = document.getElementById("secret-state");
    const submitButton = form.querySelector("button[type='submit']");

    function buildMapUrl(lat, lon) {
      const pad = 0.01;
      const west = lon - pad;
      const east = lon + pad;
      const south = lat - pad;
      const north = lat + pad;
      return `https://www.openstreetmap.org/export/embed.html?bbox=${west}%2C${south}%2C${east}%2C${north}&layer=mapnik&marker=${lat}%2C${lon}`;
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (message instanceof HTMLElement) {
        message.textContent = "Ověřuji kód...";
        message.dataset.tone = "warning";
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      const slug = form.dataset.slug;
      const unlockCode = input instanceof HTMLInputElement ? input.value : "";

      try {
        const response = await fetch(`/api/events/${slug}/unlock`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ unlockCode }),
        });

        const result = await response.json();

        if (!response.ok || !result?.ok) {
          if (message instanceof HTMLElement) {
            message.textContent = result?.error?.message || "Kód je neplatný.";
            message.dataset.tone = "danger";
          }
          return;
        }

        const secret = result.data;
        if (locationEl instanceof HTMLElement) locationEl.textContent = secret.secretLocationName;
        if (infoEl instanceof HTMLElement) infoEl.textContent = secret.secretInfo;
        if (noteEl instanceof HTMLElement) noteEl.textContent = secret.secretMapNote || "";
        if (noteWrap instanceof HTMLElement) noteWrap.hidden = !secret.secretMapNote;
        if (mapEl instanceof HTMLIFrameElement) {
          mapEl.src = buildMapUrl(secret.secretLatitude, secret.secretLongitude);
        }
        if (content instanceof HTMLElement) content.hidden = false;
        if (secretState instanceof HTMLElement) {
          secretState.textContent = "UNLOCKED";
          secretState.classList.add("meta-pill-positive");
        }
        if (message instanceof HTMLElement) {
          message.textContent = "Tajné informace odemčeny.";
          message.dataset.tone = "positive";
        }
      } catch {
        if (message instanceof HTMLElement) {
          message.textContent = "Nepodařilo se ověřit kód, zkuste to znovu.";
          message.dataset.tone = "danger";
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }
      }
    });
  }
</script>

<style>
  :global(.grid-canvas) {
    display: none;
  }

  :global(body.event-body) {
    scroll-snap-type: none;
  }

  .event-shell {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: 36px 20px 72px;
  }

  .event-grid-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    min-height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .event-grid-canvas .v,
  .event-grid-canvas .h {
    position: absolute;
    background: rgba(0, 0, 0, 0.85);
  }

  .event-grid-canvas .v {
    left: var(--x);
    top: 0;
    width: var(--w, 3px);
    height: 100%;
  }

  .event-grid-canvas .h {
    top: var(--y);
    left: 0;
    height: var(--w, 3px);
    width: 100%;
  }

  .event-bg {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background: url("/bg.jpeg");
    background-size: cover;
    z-index: 0;
  }

  .bunkr {
    position: absolute;
    right: -50px;
    bottom: -40px;
    width: 380px;
    z-index: 0;
    opacity: 0.55;
  }

  .event-layout {
    position: relative;
    z-index: 1;
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    gap: 20px;
  }

  .event-layout-missing {
    max-width: 760px;
  }

  .event-topbar {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
  }

  .back-link,
  .event-slug,
  .meta-pill,
  .secret-label {
    border: 2px solid #000;
    padding: 8px 10px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: #000;
    background: rgba(255, 245, 214, 0.86);
  }

  .back-link:hover {
    background: #000;
    color: #c00;
  }

  .event-slug {
    background: rgba(255, 255, 255, 0.72);
    overflow-wrap: anywhere;
  }

  .event-card {
    border: 3px solid #000;
    box-shadow: 14px 14px 0 #000;
    padding: 22px;
    display: grid;
    gap: 16px;
  }

  .public-card {
    background: rgba(255, 244, 221, 0.92);
  }

  .secret-card {
    background:
      linear-gradient(135deg, rgba(20, 20, 20, 0.96), rgba(70, 12, 12, 0.96)),
      #111;
    color: #fff5e1;
  }

  .card-head,
  .meta-pills,
  .unlock-form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }

  .card-head {
    justify-content: space-between;
    align-items: start;
  }

  .card-kicker {
    font-size: 0.84rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .public-card h1,
  .secret-card h2 {
    font-size: clamp(2.2rem, 6vw, 4.4rem);
    line-height: 0.95;
  }

  .event-date {
    font-size: 1.2rem;
    text-transform: uppercase;
  }

  .event-cover {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border: 3px solid #000;
    background: rgba(0, 0, 0, 0.08);
  }

  .card-copy {
    max-width: 60ch;
    line-height: 1.55;
    font-size: 1.1rem;
  }

  .meta-pill {
    background: #000;
    color: #c00;
  }

  .meta-pill-soft {
    background: rgba(255, 255, 255, 0.72);
    color: #000;
  }

  .meta-pill-positive {
    background: #8ef1b0;
    color: #000;
  }

  .unlock-form {
    align-items: end;
  }

  .unlock-field {
    display: grid;
    gap: 8px;
    flex: 1 1 340px;
  }

  .unlock-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .secret-input,
  .secret-button {
    border: 3px solid #000;
    padding: 12px 14px;
    box-sizing: border-box;
    font-family: var(--font-body);
  }

  .secret-input {
    width: 100%;
    background: #c00;
    color: #000;
    font-size: 1.15rem;
  }

  .secret-input::placeholder {
    color: rgba(0, 0, 0, 0.72);
  }

  .secret-button {
    min-width: 210px;
    background: #000;
    color: #c00;
    font-family: var(--font-display);
    font-size: 1.2rem;
    cursor: pointer;
  }

  .secret-button:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .unlock-message {
    min-height: 24px;
    margin: 0;
    font-weight: 700;
  }

  .unlock-message[data-tone="warning"] {
    color: #f7d182;
  }

  .unlock-message[data-tone="positive"] {
    color: #8ef1b0;
  }

  .unlock-message[data-tone="danger"] {
    color: #ffb5b5;
  }

  .secret-content {
    display: grid;
    gap: 14px;
  }

  .secret-block {
    display: grid;
    gap: 8px;
  }

  .secret-label {
    background: rgba(255, 255, 255, 0.08);
    color: #fff5e1;
    width: fit-content;
  }

  #secret-info,
  #secret-note {
    line-height: 1.55;
    max-width: 60ch;
  }

  #secret-map {
    border: 0;
    width: 100%;
  }

  @media (max-width: 768px) {
    .event-shell {
      padding: 20px 12px 42px;
    }

    .event-topbar,
    .card-head,
    .unlock-form {
      flex-direction: column;
      align-items: stretch;
    }

    .event-card {
      padding: 16px;
      box-shadow: 8px 8px 0 #000;
    }

    .public-card h1,
    .secret-card h2 {
      font-size: 1.8rem;
    }

    .event-date,
    .card-copy,
    #secret-info,
    #secret-note {
      font-size: 1rem;
    }

    .secret-button {
      width: 100%;
      min-width: 0;
    }

    .event-slug {
      width: 100%;
      box-sizing: border-box;
    }

    .bunkr {
      width: 180px;
      right: -20px;
      bottom: -12px;
      opacity: 0.45;
    }

    #secret-map {
      height: 240px;
    }
  }
</style>
